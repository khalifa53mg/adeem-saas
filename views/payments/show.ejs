<%- include('../partials/head') %>
<% const isAr = (locals.lang || 'en') === 'ar'; %>
<div class="app-wrapper">
  <%- include('../partials/sidebar') %>

  <div class="main-content">
    <div class="topbar">
      <span class="topbar-title">
        <a href="/payments" class="text-muted text-decoration-none"><i class="bi bi-cash-stack"></i> <%= isAr ? 'المدفوعات' : 'Payments' %></a>
        <i class="bi bi-chevron-right mx-2 text-dim" style="font-size:11px;"></i>
        <%= isAr ? 'إيصال' : 'Receipt' %> #<%= payment.receipt_number %>
      </span>
      <div class="topbar-actions no-print">
        <a href="/payments/<%= payment.id %>/edit" class="btn btn-outline-primary btn-sm">
          <i class="bi bi-pencil"></i> <%= isAr ? 'تعديل' : 'Edit' %>
        </a>
        <a href="/payments/<%= payment.id %>/pdf" class="btn btn-outline-secondary btn-sm">
          <i class="bi bi-file-earmark-pdf"></i> <%= isAr ? 'تحميل PDF' : 'Download PDF' %>
        </a>
        <a href="/payments/<%= payment.id %>/pdf?noname=1" class="btn btn-outline-secondary btn-sm">
          <i class="bi bi-file-earmark-pdf"></i> PDF (<%= isAr ? 'بدون اسم' : 'No Name' %>)
        </a>
        <button onclick="window.print()" class="btn btn-outline-secondary btn-sm">
          <i class="bi bi-printer"></i> <%= isAr ? 'طباعة' : 'Print' %>
        </button>
        <% if (locals.user && locals.user.role === 'admin') { %>
        <form method="POST" action="/payments/<%= payment.id %>/delete" class="d-inline">
          <button type="submit" class="btn btn-outline-danger btn-sm"
                  data-confirm="<%= isAr ? 'حذف الإيصال' : 'Delete Receipt' %> #<%= payment.receipt_number %>?">
            <i class="bi bi-trash"></i> <%= isAr ? 'حذف' : 'Delete' %>
          </button>
        </form>
        <% } %>
      </div>
    </div>

    <div class="page-body">
      <% if (flash) { %>
      <div class="alert alert-<%= flash.type %> mb-3 no-print" data-autohide><%= flash.msg %></div>
      <% } %>

      <div class="receipt-wrap">
        <!-- Receipt Card -->
        <div class="card">
          <div class="card-body p-4">
            <!-- Header -->
            <div class="d-flex justify-content-between align-items-start mb-4">
              <div>
                <h4 class="fw-700 mb-1" style="font-size:20px;"><%= settings.owner_name %></h4>
                <% if (settings.tel) { %><div class="text-muted" style="font-size:12.5px;">Tel: <%= settings.tel %><% if (settings.fax) { %> | Fax: <%= settings.fax %><% } %></div><% } %>
                <% if (settings.po_box) { %><div class="text-muted" style="font-size:12.5px;">P.O. Box: <%= settings.po_box %></div><% } %>
                <% if (settings.address) { %><div class="text-muted" style="font-size:12.5px;"><%= settings.address %></div><% } %>
              </div>
              <div class="text-end">
                <div style="font-size:24px;font-weight:800;color:var(--accent);">RECEIPT</div>
                <div style="font-size:18px;font-weight:700;">#<%= payment.receipt_number %></div>
                <div class="text-muted" style="font-size:12.5px;">Date: <%= payment.payment_date %></div>
              </div>
            </div>

            <hr style="border-color:var(--border-color);">

            <!-- Tenant + Unit info -->
            <div class="row mb-4">
              <div class="col-6">
                <div class="info-label mb-2"><%= isAr ? 'مستلم من' : 'Received From' %></div>
                <div class="fw-700" style="font-size:15px;"><%= payment.tenant_name %></div>
                <% if (payment.tenant_address) { %><div class="text-muted" style="font-size:12.5px;"><%= payment.tenant_address %></div><% } %>
                <% if (payment.tenant_tel) { %><div class="text-muted" style="font-size:12.5px;">Tel: <%= payment.tenant_tel %></div><% } %>
              </div>
              <div class="col-6">
                <div class="info-label mb-2"><%= isAr ? 'للعقار / الوحدة' : 'For Property / Unit' %></div>
                <div class="fw-600" style="font-size:14px;"><%= payment.property_name %></div>
                <div class="text-muted" style="font-size:13px;">
                  <%= payment.unit_number ? payment.unit_number + ' — ' : '' %><%= payment.unit_name %>
                </div>
                <% if (payment.property_location) { %><div class="text-dim" style="font-size:12px;"><%= payment.property_location %></div><% } %>
              </div>
            </div>

            <!-- Payment Details -->
            <div class="card mb-3" style="background:var(--bg-page);">
              <div class="card-body p-3">
                <div class="row g-2">
                  <div class="col-6 col-md-3">
                    <div class="info-label"><%= isAr ? 'المبلغ' : 'Amount' %></div>
                    <div class="fw-700 text-success" style="font-size:18px;"><%= currencyLabel %> <%= payment.total_amount.toFixed(currencyDecimals) %></div>
                  </div>
                  <div class="col-6 col-md-3">
                    <div class="info-label"><%= isAr ? 'الطريقة' : 'Method' %></div>
                    <div class="fw-600"><span class="badge badge-<%= payment.payment_method %>" style="font-size:12.5px;"><%= payment.payment_method.toUpperCase() %></span></div>
                  </div>
                  <% if (payment.bank_name) { %>
                  <div class="col-6 col-md-3">
                    <div class="info-label"><%= isAr ? 'البنك' : 'Bank' %></div>
                    <div class="fw-600"><%= payment.bank_name %></div>
                  </div>
                  <% } %>
                  <% if (payment.cheque_number) { %>
                  <div class="col-6 col-md-3">
                    <div class="info-label"><%= isAr ? 'رقم الشيك' : 'Cheque #' %></div>
                    <div class="fw-600"><%= payment.cheque_number %></div>
                  </div>
                  <% } %>
                  <% if (payment.cheque_date) { %>
                  <div class="col-6 col-md-3">
                    <div class="info-label"><%= isAr ? 'تاريخ الشيك' : 'Cheque Date' %></div>
                    <div class="fw-600"><%= payment.cheque_date %></div>
                  </div>
                  <% } %>
                </div>
              </div>
            </div>

            <!-- Allocations -->
            <%
              const totalAllocated = allocations.reduce((s, a) => s + a.amount_allocated, 0);
              const unallocated = payment.total_amount - totalAllocated;
            %>
            <% if (allocations.length > 0) { %>
            <div class="mb-3">
              <div class="info-label mb-2"><%= isAr ? 'توزيع الأشهر' : 'Month Allocations' %></div>
              <div class="table-responsive">
                <table class="table mb-0" style="font-size:13px;">
                  <thead>
                    <tr>
                      <th style="padding:6px 10px;"><%= isAr ? 'الشهر' : 'Month' %></th>
                      <th style="padding:6px 10px;"><%= isAr ? 'المبلغ' : 'Amount' %> (<%= currencyLabel %>)</th>
                      <th style="padding:6px 10px;"><%= isAr ? 'الحالة' : 'Status' %></th>
                    </tr>
                  </thead>
                  <tbody>
                    <% allocations.forEach(a => { %>
                    <tr>
                      <td style="padding:6px 10px;"><%= a.month %></td>
                      <td style="padding:6px 10px;" class="fw-600"><%= a.amount_allocated.toFixed(currencyDecimals) %></td>
                      <td style="padding:6px 10px;">
                        <span class="badge badge-<%= a.status %>">
                          <%= isAr ? (a.status === 'paid' ? 'مدفوع' : a.status === 'partial' ? 'جزئي' : 'غير مدفوع') : a.status %>
                        </span>
                      </td>
                    </tr>
                    <% }) %>
                  </tbody>
                  <tfoot>
                    <tr style="border-top:2px solid var(--border-color);">
                      <td style="padding:6px 10px;" class="fw-700"><%= isAr ? 'إجمالي المخصص' : 'Total Allocated' %></td>
                      <td style="padding:6px 10px;" class="fw-700 text-success"><%= currencyLabel %> <%= totalAllocated.toFixed(currencyDecimals) %></td>
                      <td></td>
                    </tr>
                    <tr>
                      <td style="padding:6px 10px;" class="fw-700"><%= isAr ? 'إجمالي المدفوع' : 'Total Paid' %></td>
                      <td style="padding:6px 10px;" class="fw-700"><%= currencyLabel %> <%= payment.total_amount.toFixed(currencyDecimals) %></td>
                      <td></td>
                    </tr>
                    <tr>
                      <td style="padding:6px 10px;" class="fw-700"><%= isAr ? 'الرصيد غير المخصص' : 'Unallocated Balance' %></td>
                      <td style="padding:6px 10px;" class="fw-700 <%= unallocated > 0.001 ? 'text-danger' : 'text-success' %>">
                        <%= currencyLabel %> <%= unallocated.toFixed(currencyDecimals) %>
                      </td>
                      <td style="padding:6px 10px;">
                        <% if (unallocated > 0.001) { %>
                        <span class="badge badge-unpaid"><%= isAr ? 'غير مخصص' : 'Not Assigned' %></span>
                        <% } else { %>
                        <span class="badge badge-paid"><%= isAr ? 'مخصص بالكامل' : 'Fully Assigned' %></span>
                        <% } %>
                      </td>
                    </tr>
                  </tfoot>
                </table>
              </div>
            </div>
            <% } %>

            <% if (allocations.length === 0 && payment.total_amount > 0) { %>
            <div class="alert alert-warning mb-3 no-print">
              <i class="bi bi-exclamation-triangle me-2"></i>
              <strong><%= currencyLabel %> <%= payment.total_amount.toFixed(currencyDecimals) %> <%= isAr ? 'غير مخصص بالكامل.' : 'is fully unallocated.' %></strong>
              <%= isAr ? 'لم يتم تخصيص هذه الدفعة لأي شهر إيجار.' : 'This payment has not been assigned to any rental month.' %>
            </div>
            <% } %>

            <% if (allocations.length > 0 && unallocated > 0.001) { %>
            <div class="alert alert-warning mb-3 no-print">
              <i class="bi bi-exclamation-triangle me-2"></i>
              <strong><%= currencyLabel %> <%= unallocated.toFixed(currencyDecimals) %> <%= isAr ? 'غير مخصص.' : 'is unallocated.' %></strong>
              <%= isAr ? 'هذا المبلغ مدفوع لكن غير مخصص لأي شهر إيجار.' : 'This amount was paid but not assigned to any rental month.' %>
            </div>
            <% } %>

            <% if (payment.notes) { %>
            <div class="mb-3">
              <div class="info-label mb-1"><%= isAr ? 'ملاحظات' : 'Notes' %></div>
              <div style="font-size:13.5px;"><%= payment.notes %></div>
            </div>
            <% } %>

            <hr style="border-color:var(--border-color);">

            <!-- Footer -->
            <div class="d-flex justify-content-between align-items-end" style="font-size:12px;color:var(--text-dim);">
              <div>
                <% if (settings.receipt_footer_note) { %>
                <em><%= settings.receipt_footer_note %></em>
                <% } %>
              </div>
              <div class="text-end">
                <% if (payment.created_by_name) { %>
                <%= isAr ? 'تم التسجيل بواسطة:' : 'Recorded by:' %> <%= payment.created_by_name %><br>
                <% } %>
                <%= new Date(payment.created_at).toLocaleString() %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/scripts') %>
