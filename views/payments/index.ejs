<%- include('../partials/head') %>
<% const isAr = (locals.lang || 'en') === 'ar'; %>
<div class="app-wrapper">
  <%- include('../partials/sidebar') %>

  <div class="main-content">
    <div class="topbar">
      <span class="topbar-title"><i class="bi bi-cash-stack me-2"></i><%= isAr ? 'المدفوعات' : 'Payments' %></span>
      <div class="topbar-actions">
        <a href="/payments/new" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg"></i> <%= isAr ? 'تسجيل دفعة' : 'Record Payment' %></a>
      </div>
    </div>

    <div class="page-body">
      <% if (flash) { %>
      <div class="alert alert-<%= flash.type %> mb-3" data-autohide><%= flash.msg %></div>
      <% } %>

      <!-- Filter bar -->
      <form method="GET" action="/payments" class="filter-bar">
        <div class="flex-fill" style="min-width:160px;">
          <label class="form-label mb-1"><%= isAr ? 'بحث' : 'Search' %></label>
          <input type="text" name="search" class="form-control" placeholder="<%= isAr ? 'رقم الإيصال، شيك…' : 'Receipt #, cheque…' %>" value="<%= search %>">
        </div>
        <div style="min-width:150px;">
          <label class="form-label mb-1"><%= isAr ? 'المبنى' : 'Building' %></label>
          <select name="property_id" class="form-select">
            <option value=""><%= isAr ? 'جميع المباني' : 'All Buildings' %></option>
            <% filterProperties.forEach(pr => { %>
            <option value="<%= pr.id %>" <%= propertyFilter === String(pr.id) ? 'selected' : '' %>><%= pr.name %></option>
            <% }) %>
          </select>
        </div>
        <div style="min-width:150px;">
          <label class="form-label mb-1"><%= isAr ? 'المستأجر' : 'Tenant' %></label>
          <select name="tenant_id" class="form-select">
            <option value=""><%= isAr ? 'جميع المستأجرين' : 'All Tenants' %></option>
            <% filterTenants.forEach(tn => { %>
            <option value="<%= tn.id %>" <%= tenantFilter === String(tn.id) ? 'selected' : '' %>><%= tn.full_name %></option>
            <% }) %>
          </select>
        </div>
        <div style="min-width:150px;">
          <label class="form-label mb-1"><%= isAr ? 'الوحدة' : 'Unit' %></label>
          <select name="unit_id" class="form-select">
            <option value=""><%= isAr ? 'جميع الوحدات' : 'All Units' %></option>
            <% filterUnits.forEach(u => { %>
            <option value="<%= u.id %>" <%= unitFilter === String(u.id) ? 'selected' : '' %>>
              <%= u.property_name %> — <%= u.unit_number ? u.unit_number + ' ' : '' %><%= u.unit_name %>
            </option>
            <% }) %>
          </select>
        </div>
        <div style="min-width:120px;">
          <label class="form-label mb-1"><%= isAr ? 'الطريقة' : 'Method' %></label>
          <select name="method" class="form-select">
            <option value=""><%= isAr ? 'جميع الطرق' : 'All Methods' %></option>
            <option value="cash"     <%= methodFilter === 'cash'     ? 'selected' : '' %>><%= isAr ? 'نقداً' : 'Cash' %></option>
            <option value="cheque"   <%= methodFilter === 'cheque'   ? 'selected' : '' %>><%= isAr ? 'شيك' : 'Cheque' %></option>
            <option value="transfer" <%= methodFilter === 'transfer' ? 'selected' : '' %>><%= isAr ? 'تحويل' : 'Transfer' %></option>
            <option value="card"     <%= methodFilter === 'card'     ? 'selected' : '' %>><%= isAr ? 'بطاقة' : 'Card' %></option>
          </select>
        </div>
        <div style="min-width:120px;">
          <label class="form-label mb-1"><%= isAr ? 'من' : 'From' %></label>
          <input type="date" name="date_from" class="form-control" value="<%= dateFrom %>">
        </div>
        <div style="min-width:120px;">
          <label class="form-label mb-1"><%= isAr ? 'إلى' : 'To' %></label>
          <input type="date" name="date_to" class="form-control" value="<%= dateTo %>">
        </div>
        <div class="d-flex align-items-end gap-2">
          <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-search"></i> <%= isAr ? 'تصفية' : 'Filter' %></button>
          <a href="/payments" class="btn btn-outline-secondary btn-sm"><%= isAr ? 'إعادة تعيين' : 'Reset' %></a>
        </div>
      </form>

      <!-- Summary row -->
      <% const totalShown = payments.reduce((s, p) => s + p.total_amount, 0); %>
      <% if (payments.length > 0) { %>
      <div class="d-flex gap-2 mb-3 align-items-center" style="font-size:12.5px;">
        <span class="text-muted"><%= isAr ? 'عرض' : 'Showing' %> <strong class="text-primary-c"><%= payments.length %></strong> <%= isAr ? 'من' : 'of' %> <strong class="text-primary-c"><%= total %></strong> <%= isAr ? 'دفعة' : 'payments' %></span>
        <span class="ms-auto fw-600 text-success"><%= currencyLabel %> <%= totalShown.toFixed(3) %> <%= isAr ? 'معروضة' : 'shown' %></span>
      </div>
      <% } %>

      <!-- Table -->
      <div class="card">
        <% if (payments.length === 0) { %>
        <div class="empty-state">
          <div class="empty-icon">💳</div>
          <h6><%= isAr ? 'لا توجد مدفوعات' : 'No Payments Found' %></h6>
          <p><% if (search || methodFilter || dateFrom || dateTo) { %><%= isAr ? 'لا توجد مدفوعات تطابق المرشحات.' : 'No payments match your filters.' %> <a href="/payments"><%= isAr ? 'مسح' : 'Clear' %></a><% } else { %><%= isAr ? 'سجّل الدفعة الأولى.' : 'Record the first payment.' %><% } %></p>
          <a href="/payments/new" class="btn btn-primary btn-sm mt-2"><i class="bi bi-plus-lg"></i> <%= isAr ? 'تسجيل دفعة' : 'Record Payment' %></a>
        </div>
        <% } else { %>
        <div class="table-responsive">
          <table class="table mb-0">
            <thead>
              <tr>
                <th><%= isAr ? 'التاريخ' : 'Date' %></th>
                <th><%= isAr ? 'رقم الإيصال' : 'Receipt #' %></th>
                <th><%= isAr ? 'المستأجر' : 'Tenant' %></th>
                <th><%= isAr ? 'الوحدة' : 'Unit' %></th>
                <th><%= isAr ? 'المبلغ' : 'Amount' %></th>
                <th><%= isAr ? 'الطريقة' : 'Method' %></th>
                <th><%= isAr ? 'الأشهر المدفوعة' : 'Months Paid' %></th>
                <th><%= isAr ? 'الرصيد' : 'Balance' %></th>
                <th><%= isAr ? 'بواسطة' : 'By' %></th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% payments.forEach(p => { %>
              <tr>
                <td style="white-space:nowrap;"><%= p.payment_date %></td>
                <td><span class="fw-700 text-accent">#<%= p.receipt_number %></span></td>
                <td>
                  <a href="/tenants/<%= p.tenant_id %>" class="fw-600 text-primary-c text-decoration-none"><%= p.tenant_name %></a>
                </td>
                <td>
                  <a href="/units/<%= p.sub_property_id %>" class="text-muted text-decoration-none" style="font-size:12.5px;">
                    <div><%= p.property_name %></div>
                    <div><%= p.unit_number ? p.unit_number + ' — ' : '' %><%= p.unit_name %></div>
                  </a>
                </td>
                <td class="fw-700 text-success" style="white-space:nowrap;"><%= currencyLabel %> <%= p.total_amount.toFixed(3) %></td>
                <td><span class="badge badge-<%= p.payment_method %>"><%= p.payment_method %></span></td>
                <td style="font-size:11.5px;color:var(--text-muted);max-width:180px;">
                  <% if (p.months_label) { %>
                  <span title="<%= p.months_label %>"><%= p.months_label %></span>
                  <% } else { %>
                  <span class="text-dim">—</span>
                  <% } %>
                </td>
                <td style="white-space:nowrap;">
                  <% if (p.unallocated > 0.001) { %>
                  <span class="text-danger fw-600" style="font-size:12.5px;" title="Unallocated"><%= currencyLabel %> <%= p.unallocated.toFixed(3) %></span>
                  <% } else { %>
                  <span class="text-success" style="font-size:12px;">✓ <%= isAr ? 'مكتمل' : 'Full' %></span>
                  <% } %>
                </td>
                <td style="font-size:12px;color:var(--text-muted);white-space:nowrap;">
                  <%= p.created_by_name || '—' %>
                </td>
                <td class="text-end">
                  <a href="/payments/<%= p.id %>" class="btn btn-outline-secondary btn-sm"><%= isAr ? 'عرض' : 'View' %></a>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <% const totalPages = Math.ceil(total / perPage); %>
        <% const qs = `&search=${search}&method=${methodFilter}&date_from=${dateFrom}&date_to=${dateTo}&property_id=${propertyFilter}&tenant_id=${tenantFilter}&unit_id=${unitFilter}`; %>
        <% if (totalPages > 1) { %>
        <div class="p-3 d-flex justify-content-center">
          <nav>
            <ul class="pagination pagination-sm mb-0">
              <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
                <a class="page-link" href="?page=<%= page - 1 %><%= qs %>">‹</a>
              </li>
              <% for (let i = Math.max(1, page-2); i <= Math.min(totalPages, page+2); i++) { %>
              <li class="page-item <%= i === page ? 'active' : '' %>">
                <a class="page-link" href="?page=<%= i %><%= qs %>"><%= i %></a>
              </li>
              <% } %>
              <li class="page-item <%= page >= totalPages ? 'disabled' : '' %>">
                <a class="page-link" href="?page=<%= page + 1 %><%= qs %>">›</a>
              </li>
            </ul>
          </nav>
        </div>
        <% } %>
        <% } %>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/scripts') %>
