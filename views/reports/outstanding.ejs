<%- include('../partials/head') %>
<div class="app-wrapper">
  <%- include('../partials/sidebar') %>

  <div class="main-content">
    <div class="topbar">
      <span class="topbar-title">
        <a href="/reports" class="text-muted text-decoration-none"><i class="bi bi-bar-chart-line"></i> Reports</a>
        <i class="bi bi-chevron-right mx-2 text-dim" style="font-size:11px;"></i>
        Outstanding Balances
      </span>
      <div class="topbar-actions no-print">
        <button onclick="window.print()" class="btn btn-outline-secondary btn-sm"><i class="bi bi-printer"></i> Print</button>
      </div>
    </div>

    <div class="page-body">
      <!-- Summary -->
      <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
          <div class="stat-card">
            <div class="stat-icon red"><i class="bi bi-exclamation-circle"></i></div>
            <div>
              <div class="stat-label">Units with Arrears</div>
              <div class="stat-value"><%= outstanding.length %></div>
            </div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="stat-card">
            <div class="stat-icon orange"><i class="bi bi-currency-dollar"></i></div>
            <div>
              <div class="stat-label">Total Outstanding</div>
              <div class="stat-value" style="font-size:16px;">BD <%= grandTotal.toFixed(3) %></div>
            </div>
          </div>
        </div>
        <div class="col-12 col-md-6">
          <div class="stat-card">
            <div class="stat-icon blue"><i class="bi bi-calendar-range"></i></div>
            <div>
              <div class="stat-label">Checking Period</div>
              <div class="stat-value" style="font-size:13px;"><%= checkMonths[checkMonths.length - 1] %> → <%= checkMonths[0] %></div>
              <div class="stat-sub">Last 6 months</div>
            </div>
          </div>
        </div>
      </div>

      <% if (outstanding.length === 0) { %>
      <div class="card">
        <div class="empty-state">
          <div class="empty-icon" style="font-size:48px;">✅</div>
          <h6>No Outstanding Balances</h6>
          <p>All rented units are fully paid for the last 6 months.</p>
        </div>
      </div>
      <% } else { %>
      <% outstanding.forEach(u => { %>
      <div class="card mb-3">
        <div class="card-header" style="gap:12px;">
          <div class="d-flex align-items-center gap-2">
            <i class="bi bi-house-door text-danger"></i>
            <div>
              <a href="/units/<%= u.id %>" class="fw-700 text-primary-c text-decoration-none" style="font-size:14px;">
                <%= u.unit_number ? u.unit_number + ' — ' : '' %><%= u.unit_name %>
              </a>
              <span class="text-muted ms-2" style="font-size:12px;"><%= u.property_name %></span>
            </div>
          </div>
          <div class="d-flex align-items-center gap-3">
            <div class="text-end">
              <div style="font-size:11px;color:var(--text-dim);">Tenant</div>
              <a href="/tenants/<%= u.tenant_id %>" class="text-decoration-none text-muted fw-600" style="font-size:13px;">
                <%= u.tenant_name %>
              </a>
              <% if (u.tenant_tel) { %>
              <span class="text-dim ms-2" style="font-size:12px;"><i class="bi bi-telephone"></i> <%= u.tenant_tel %></span>
              <% } %>
            </div>
            <div class="text-end">
              <div style="font-size:11px;color:var(--text-dim);">Total Owed</div>
              <div class="fw-700 text-danger" style="font-size:16px;">BD <%= u.totalOwed.toFixed(3) %></div>
            </div>
          </div>
        </div>
        <div class="table-responsive">
          <table class="table mb-0" style="font-size:13px;">
            <thead>
              <tr>
                <th>Month</th>
                <th>Rent Due (BD)</th>
                <th>Paid (BD)</th>
                <th>Outstanding (BD)</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% u.unpaidMonths.forEach(m => { %>
              <tr>
                <td class="fw-600"><%= m.month %></td>
                <td>BD <%= u.monthly_rent_bhd.toFixed(3) %></td>
                <td class="<%= m.paid > 0 ? 'text-success' : 'text-dim' %>">
                  <%= m.paid > 0 ? 'BD ' + m.paid.toFixed(3) : '—' %>
                </td>
                <td class="fw-700 text-danger">BD <%= m.owed.toFixed(3) %></td>
                <td class="text-end">
                  <a href="/payments/new?unit_id=<%= u.id %>" class="btn btn-primary btn-sm">
                    <i class="bi bi-cash-stack"></i> Record Payment
                  </a>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
      <% }) %>
      <% } %>
    </div>
  </div>
</div>
<%- include('../partials/scripts') %>
