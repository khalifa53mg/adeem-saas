<%- include('../partials/head') %>
<% const isAr = (locals.lang || 'en') === 'ar'; %>
<div class="app-wrapper">
  <%- include('../partials/sidebar') %>

  <div class="main-content">
    <div class="topbar">
      <span class="topbar-title">
        <a href="/reports" class="text-muted text-decoration-none"><i class="bi bi-bar-chart-line"></i> <%= isAr ? 'التقارير' : 'Reports' %></a>
        <i class="bi bi-chevron-right mx-2 text-dim" style="font-size:11px;"></i>
        <%= isAr ? 'تقرير الدخل' : 'Income Report' %>
      </span>
      <div class="topbar-actions">
        <a href="/reports/income/export?year=<%= yearFilter %>&month=<%= monthFilter %>&property_id=<%= propFilter %>"
           class="btn btn-outline-secondary btn-sm">
          <i class="bi bi-file-earmark-excel"></i> <%= isAr ? 'تصدير Excel' : 'Export Excel' %>
        </a>
      </div>
    </div>

    <div class="page-body">
      <!-- Filters -->
      <form method="GET" action="/reports/income" class="filter-bar">
        <div style="min-width:100px;">
          <label class="form-label mb-1"><%= isAr ? 'السنة' : 'Year' %></label>
          <select name="year" class="form-select">
            <% years.forEach(y => { %>
            <option value="<%= y %>" <%= yearFilter === y ? 'selected' : '' %>><%= y %></option>
            <% }) %>
          </select>
        </div>
        <div style="min-width:120px;">
          <label class="form-label mb-1"><%= isAr ? 'الشهر' : 'Month' %></label>
          <select name="month" class="form-select">
            <option value=""><%= isAr ? 'جميع الأشهر' : 'All Months' %></option>
            <% ['01','02','03','04','05','06','07','08','09','10','11','12'].forEach((m, i) => {
              const namesEn = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
              const namesAr = ['يناير','فبراير','مارس','أبريل','مايو','يونيو','يوليو','أغسطس','سبتمبر','أكتوبر','نوفمبر','ديسمبر'];
            %>
            <option value="<%= m %>" <%= monthFilter === m ? 'selected' : '' %>><%= isAr ? namesAr[i] : namesEn[i] %></option>
            <% }) %>
          </select>
        </div>
        <div class="flex-fill" style="min-width:160px;">
          <label class="form-label mb-1"><%= isAr ? 'العقار' : 'Property' %></label>
          <select name="property_id" class="form-select">
            <option value=""><%= isAr ? 'جميع العقارات' : 'All Properties' %></option>
            <% properties.forEach(p => { %>
            <option value="<%= p.id %>" <%= propFilter == p.id ? 'selected' : '' %>><%= p.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="d-flex align-items-end gap-2">
          <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-search"></i> <%= isAr ? 'تصفية' : 'Filter' %></button>
          <a href="/reports/income" class="btn btn-outline-secondary btn-sm"><%= isAr ? 'إعادة تعيين' : 'Reset' %></a>
        </div>
      </form>

      <!-- Summary -->
      <div class="row g-3 mb-3">
        <div class="col-12 col-md-4">
          <div class="stat-card">
            <div class="stat-icon green"><i class="bi bi-cash-stack"></i></div>
            <div>
              <div class="stat-label"><%= isAr ? 'إجمالي الدخل' : 'Total Income' %></div>
              <div class="stat-value" style="font-size:18px;"><%= currencyLabel %> <%= totalIncome.toFixed(currencyDecimals) %></div>
            </div>
          </div>
        </div>
        <div class="col-12 col-md-4">
          <div class="stat-card">
            <div class="stat-icon blue"><i class="bi bi-receipt"></i></div>
            <div>
              <div class="stat-label"><%= isAr ? 'المدفوعات' : 'Payments' %></div>
              <div class="stat-value"><%= payments.length %></div>
            </div>
          </div>
        </div>
        <div class="col-12 col-md-4">
          <div class="stat-card">
            <div class="stat-icon orange"><i class="bi bi-buildings"></i></div>
            <div>
              <div class="stat-label"><%= isAr ? 'العقارات' : 'Properties' %></div>
              <div class="stat-value"><%= Object.keys(byProperty).length %></div>
            </div>
          </div>
        </div>
      </div>

      <!-- By Property breakdown -->
      <% if (Object.keys(byProperty).length > 1) { %>
      <div class="card mb-3">
        <div class="card-header"><%= isAr ? 'حسب العقار' : 'By Property' %></div>
        <div class="table-responsive">
          <table class="table mb-0">
            <thead>
              <tr>
                <th><%= isAr ? 'العقار' : 'Property' %></th>
                <th><%= isAr ? 'المدفوعات' : 'Payments' %></th>
                <th><%= isAr ? 'الإجمالي' : 'Total' %> (<%= currencyLabel %>)</th>
              </tr>
            </thead>
            <tbody>
              <% Object.values(byProperty).sort((a,b) => b.total - a.total).forEach(bp => { %>
              <tr>
                <td class="fw-600"><%= bp.name %></td>
                <td><%= bp.count %></td>
                <td class="fw-700 text-success"><%= currencyLabel %> <%= bp.total.toFixed(currencyDecimals) %></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
      <% } %>

      <!-- Payments table -->
      <div class="card">
        <div class="card-header"><%= isAr ? 'سجل المدفوعات' : 'Payment Records' %> (<%= payments.length %>)</div>
        <% if (payments.length === 0) { %>
        <div class="empty-state"><div class="empty-icon">💳</div><h6><%= isAr ? 'لا توجد مدفوعات' : 'No Payments' %></h6><p><%= isAr ? 'لا توجد مدفوعات تطابق المرشحات.' : 'No payments match your filters.' %></p></div>
        <% } else { %>
        <div class="table-responsive">
          <table class="table mb-0">
            <thead>
              <tr>
                <th><%= isAr ? 'التاريخ' : 'Date' %></th>
                <th><%= isAr ? 'الإيصال' : 'Receipt' %></th>
                <th><%= isAr ? 'المستأجر' : 'Tenant' %></th>
                <th><%= isAr ? 'الوحدة' : 'Unit' %></th>
                <th><%= isAr ? 'الطريقة' : 'Method' %></th>
                <th><%= isAr ? 'المبلغ' : 'Amount' %> (<%= currencyLabel %>)</th>
              </tr>
            </thead>
            <tbody>
              <% payments.forEach(p => { %>
              <tr>
                <td><%= p.payment_date %></td>
                <td><a href="/payments/<%= p.id %>" class="fw-700 text-accent text-decoration-none">#<%= p.receipt_number %></a></td>
                <td><%= p.tenant_name %></td>
                <td style="font-size:12.5px;"><%= p.property_name %> / <%= p.unit_number ? p.unit_number + ' ' : '' %><%= p.unit_name %></td>
                <td><span class="badge badge-<%= p.payment_method %>"><%= p.payment_method %></span></td>
                <td class="fw-600 text-success"><%= currencyLabel %> <%= p.total_amount.toFixed(currencyDecimals) %></td>
              </tr>
              <% }) %>
            </tbody>
            <tfoot>
              <tr>
                <td colspan="5" class="fw-700 text-end"><%= isAr ? 'الإجمالي:' : 'Total:' %></td>
                <td class="fw-700 text-success"><%= currencyLabel %> <%= totalIncome.toFixed(currencyDecimals) %></td>
              </tr>
            </tfoot>
          </table>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/scripts') %>
