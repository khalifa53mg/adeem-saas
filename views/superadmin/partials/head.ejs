<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' — ' : '' %>Super Admin — Adeem</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script>
    // Apply theme before paint to avoid flash
    (function() {
      var t = localStorage.getItem('sa_theme') || 'dark';
      document.documentElement.setAttribute('data-sa-theme', t);
    })();
  </script>
  <style>
    * { box-sizing: border-box; }
    body {
      font-family: 'Inter', sans-serif;
      min-height: 100vh;
      margin: 0;
      transition: background 0.2s, color 0.2s;
    }

    /* ── DARK theme (default) ── */
    [data-sa-theme="dark"] body, [data-sa-theme="dark"] {
      background: #0f1117;
      color: #e2e8f0;
    }
    [data-sa-theme="dark"] .sa-navbar {
      background: #1a1d27;
      border-bottom: 1px solid #2d3148;
    }
    [data-sa-theme="dark"] .sa-card {
      background: #1a1d27;
      border: 1px solid #2d3148;
      border-radius: 10px;
    }
    [data-sa-theme="dark"] .sa-stat-card {
      background: #1a1d27;
      border: 1px solid #2d3148;
      border-radius: 10px;
    }
    [data-sa-theme="dark"] .table {
      color: #e2e8f0;
    }
    [data-sa-theme="dark"] .table thead th {
      background: #12151e;
      color: #94a3b8;
      border-color: #2d3148;
    }
    [data-sa-theme="dark"] .table tbody td {
      border-color: #2d3148;
    }
    [data-sa-theme="dark"] .table-hover tbody tr:hover {
      background: #22263a;
      color: #e2e8f0;
    }
    [data-sa-theme="dark"] .form-control,
    [data-sa-theme="dark"] .form-select {
      background: #12151e;
      border-color: #2d3148;
      color: #e2e8f0;
    }
    [data-sa-theme="dark"] .form-control:focus,
    [data-sa-theme="dark"] .form-select:focus {
      background: #12151e;
      border-color: #6366f1;
      color: #e2e8f0;
      box-shadow: 0 0 0 3px rgba(99,102,241,0.15);
    }
    [data-sa-theme="dark"] .form-control::placeholder { color: #475569; }
    [data-sa-theme="dark"] .form-label { color: #94a3b8; }
    [data-sa-theme="dark"] .btn-outline-secondary {
      color: #94a3b8;
      border-color: #2d3148;
    }
    [data-sa-theme="dark"] .btn-outline-secondary:hover {
      background: #2d3148;
      color: #e2e8f0;
    }
    [data-sa-theme="dark"] .table-borderless td,
    [data-sa-theme="dark"] .table-borderless th {
      color: #e2e8f0;
      border: none;
    }
    [data-sa-theme="dark"] code {
      color: #a78bfa;
      background: #12151e;
      padding: 2px 6px;
      border-radius: 4px;
    }
    [data-sa-theme="dark"] .text-muted { color: #64748b !important; }
    [data-sa-theme="dark"] hr { border-color: #2d3148; }
    [data-sa-theme="dark"] .alert-danger { background: #3b1219; border-color: #7f1d1d; color: #fca5a5; }
    [data-sa-theme="dark"] .alert-success { background: #052e16; border-color: #14532d; color: #86efac; }
    [data-sa-theme="dark"] .alert-warning { background: #2d1f00; border-color: #78350f; color: #fde68a; }

    /* ── LIGHT theme ── */
    [data-sa-theme="light"] body, [data-sa-theme="light"] {
      background: #f1f5f9;
      color: #1e293b;
    }
    [data-sa-theme="light"] .sa-navbar {
      background: #ffffff;
      border-bottom: 1px solid #e2e8f0;
    }
    [data-sa-theme="light"] .sa-card {
      background: #ffffff;
      border: 1px solid #e2e8f0;
      border-radius: 10px;
    }
    [data-sa-theme="light"] .sa-stat-card {
      background: #ffffff;
      border: 1px solid #e2e8f0;
      border-radius: 10px;
    }
    [data-sa-theme="light"] .table thead th {
      background: #f8fafc;
      color: #64748b;
      border-color: #e2e8f0;
    }
    [data-sa-theme="light"] .table tbody td { border-color: #e2e8f0; }
    [data-sa-theme="light"] .form-control,
    [data-sa-theme="light"] .form-select {
      background: #ffffff;
      border-color: #cbd5e1;
      color: #1e293b;
    }
    [data-sa-theme="light"] code {
      color: #7c3aed;
      background: #f1f5f9;
      padding: 2px 6px;
      border-radius: 4px;
    }

    /* ── Shared ── */
    .sa-navbar {
      padding: 0.75rem 1.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .sa-navbar-brand {
      font-weight: 700;
      font-size: 1.1rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      text-decoration: none;
      color: inherit;
    }
    .sa-brand-badge {
      background: linear-gradient(135deg, #6366f1, #8b5cf6);
      color: #fff;
      font-size: 0.7rem;
      padding: 2px 8px;
      border-radius: 20px;
      font-weight: 600;
      letter-spacing: 0.05em;
    }
    .sa-main { padding: 2rem 1.5rem; max-width: 1300px; margin: 0 auto; }
    #themeToggleBtn {
      border: none;
      background: transparent;
      font-size: 1.1rem;
      cursor: pointer;
      padding: 4px 8px;
      border-radius: 6px;
      transition: background 0.15s;
    }
    [data-sa-theme="dark"] #themeToggleBtn { color: #fbbf24; }
    [data-sa-theme="dark"] #themeToggleBtn:hover { background: #2d3148; }
    [data-sa-theme="light"] #themeToggleBtn { color: #6366f1; }
    [data-sa-theme="light"] #themeToggleBtn:hover { background: #e2e8f0; }

    .login-wrap {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .login-box {
      width: 100%;
      max-width: 420px;
      padding: 2.5rem;
      border-radius: 14px;
    }
    [data-sa-theme="dark"] .login-box {
      background: #1a1d27;
      border: 1px solid #2d3148;
    }
    [data-sa-theme="light"] .login-box {
      background: #ffffff;
      border: 1px solid #e2e8f0;
      box-shadow: 0 4px 24px rgba(0,0,0,0.07);
    }
  </style>
</head>
<body>
