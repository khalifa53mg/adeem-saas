<%- include('partials/head') %>
<% const isAr = (locals.lang || 'en') === 'ar'; %>

<div class="login-page">
  <div class="login-card">
    <!-- Language toggle -->
    <div style="text-align:<%= isAr ? 'left' : 'right' %>;margin-bottom:12px;">
      <form action="/language" method="POST" style="display:inline;">
        <button type="submit" class="btn btn-outline-secondary btn-sm" style="font-size:12px;padding:2px 10px;">
          <%= isAr ? 'EN' : 'ع' %>
        </button>
      </form>
    </div>

    <div class="login-logo">
      <div class="logo-icon">🏢</div>
      <h1><%= isAr ? 'عديم العقارية' : 'Adeem Real Estate' %></h1>
      <p><%= isAr ? 'نظام إدارة العقارات' : 'Property Management System' %></p>
    </div>

    <% if (typeof registered !== 'undefined' && registered) { %>
    <div class="alert alert-success mb-3" role="alert">
      <i class="bi bi-check-circle me-2"></i><%= isAr ? 'تم التسجيل بنجاح! يرجى تسجيل الدخول باستخدام معرّف الشركة.' : 'Registration successful! Please log in with your Company ID.' %>
    </div>
    <% } %>

    <% if (error) { %>
    <div class="alert alert-danger mb-3" role="alert">
      <i class="bi bi-exclamation-circle me-2"></i><%= error %>
    </div>
    <% } %>

    <form action="/login" method="POST">
      <div class="mb-3">
        <label class="form-label"><%= isAr ? 'معرّف الشركة' : 'Company ID' %></label>
        <input
          type="text"
          name="slug"
          class="form-control"
          placeholder="your-company-id"
          value="<%= typeof slug !== 'undefined' ? slug : '' %>"
          autocomplete="off"
          required
          autofocus
        />
        <div class="form-text"><%= isAr ? 'المعرّف الفريد الذي اخترته عند التسجيل.' : 'The unique ID you chose when registering.' %></div>
      </div>
      <div class="mb-3">
        <label class="form-label"><%= isAr ? 'اسم المستخدم' : 'Username' %></label>
        <input
          type="text"
          name="username"
          class="form-control"
          placeholder="admin"
          autocomplete="username"
          required
        />
        <div class="form-text"><%= isAr ? 'اسم المستخدم الافتراضي هو' : 'Default admin username is' %> <strong>admin</strong></div>
      </div>
      <div class="mb-4">
        <label class="form-label"><%= isAr ? 'كلمة المرور' : 'Password' %></label>
        <input
          type="password"
          name="password"
          class="form-control"
          placeholder="<%= isAr ? 'أدخل كلمة المرور' : 'Enter password' %>"
          autocomplete="current-password"
          required
        />
      </div>
      <button type="submit" class="btn btn-primary w-100">
        <i class="bi bi-box-arrow-in-right"></i> <%= isAr ? 'تسجيل الدخول' : 'Sign In' %>
      </button>
    </form>

    <div class="mt-3 text-center" style="font-size:0.875rem;">
      <span style="opacity:0.6;"><%= isAr ? 'ليس لديك حساب؟' : "Don't have an account?" %></span>
      <a href="/register" class="ms-1"><%= isAr ? 'سجّل شركتك' : 'Register your company' %></a>
    </div>
  </div>
</div>

<%- include('partials/scripts') %>
