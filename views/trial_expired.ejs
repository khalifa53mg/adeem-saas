<%- include('partials/head') %>

<div data-bs-theme="light" style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:2rem;background:#f8f9fa;">
  <div style="max-width:500px;width:100%;text-align:center;">
    <div style="font-size:4rem;margin-bottom:1rem;">
      <% if (reason === 'suspended') { %>
        🚫
      <% } else { %>
        ⏰
      <% } %>
    </div>

    <% if (reason === 'suspended') { %>
      <h2 class="mb-3" style="color:var(--bs-danger, #dc3545);">Account Suspended</h2>
      <p class="mb-4" style="opacity:0.8;">
        Your account has been suspended. Please contact support to restore access.
      </p>
    <% } else { %>
      <h2 class="mb-3" style="color:var(--bs-warning, #ffc107);">Trial Period Expired</h2>
      <p class="mb-4" style="opacity:0.8;">
        Your 14-day free trial has ended
        <% if (trialExpiredAt) { %>
          on <strong><%= new Date(trialExpiredAt).toLocaleDateString() %></strong>
        <% } %>.
        Please contact us to activate your account and continue using Adeem.
      </p>
    <% } %>

    <button type="button" class="btn btn-primary mb-3 w-100" data-bs-toggle="modal" data-bs-target="#supportModal">
      <i class="bi bi-headset me-2"></i>Open Support Ticket
    </button>

    <a href="/logout" class="btn btn-outline-secondary w-100">
      <i class="bi bi-box-arrow-left me-2"></i>Back to Login
    </a>
  </div>
</div>

<!-- Support Ticket Modal -->
<div class="modal fade" id="supportModal" tabindex="-1" aria-labelledby="supportModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="supportModalLabel"><i class="bi bi-headset me-2"></i>Open Support Ticket</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div id="supportAlert" class="alert d-none"></div>
        <div id="supportForm">
          <div class="mb-3">
            <label class="form-label">Subject <span class="text-danger">*</span></label>
            <input type="text" id="ticketSubject" class="form-control" maxlength="200" placeholder="Brief description of your issue">
          </div>
          <div class="mb-3">
            <label class="form-label">Priority</label>
            <select id="ticketPriority" class="form-select">
              <option value="normal">Normal</option>
              <option value="high">High</option>
              <option value="urgent">Urgent</option>
              <option value="low">Low</option>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">Message <span class="text-danger">*</span></label>
            <textarea id="ticketMessage" class="form-control" rows="4" maxlength="2000" placeholder="Describe your issue in detail..."></textarea>
          </div>
        </div>
        <div id="supportSuccess" class="text-center py-3 d-none">
          <div style="font-size:3rem;">✅</div>
          <h5 class="mt-2">Ticket Submitted</h5>
          <p class="text-muted mb-0">We'll get back to you as soon as possible.</p>
        </div>
      </div>
      <div class="modal-footer" id="supportFooter">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" id="submitTicketBtn">
          <span id="submitBtnText">Submit Ticket</span>
          <span id="submitBtnSpinner" class="spinner-border spinner-border-sm ms-1 d-none" role="status"></span>
        </button>
      </div>
    </div>
  </div>
</div>

<script>
document.getElementById('submitTicketBtn').addEventListener('click', async function () {
  const subject = document.getElementById('ticketSubject').value.trim();
  const message = document.getElementById('ticketMessage').value.trim();
  const priority = document.getElementById('ticketPriority').value;
  const alertEl = document.getElementById('supportAlert');

  alertEl.className = 'alert d-none';
  alertEl.textContent = '';

  if (!subject || !message) {
    alertEl.className = 'alert alert-danger';
    alertEl.textContent = 'Subject and message are required.';
    return;
  }

  const btn = this;
  btn.disabled = true;
  document.getElementById('submitBtnSpinner').classList.remove('d-none');
  document.getElementById('submitBtnText').textContent = 'Submitting...';

  const resetBtn = () => {
    btn.disabled = false;
    document.getElementById('submitBtnSpinner').classList.add('d-none');
    document.getElementById('submitBtnText').textContent = 'Submit Ticket';
  };
  try {
    const response = await fetch('/support-request', {
      method: 'POST',
      credentials: 'same-origin',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ subject, message, priority })
    });
    const raw = await response.text();
    let data;
    try { data = JSON.parse(raw); } catch (_) { data = null; }
    if (data && data.ok) {
      document.getElementById('supportForm').classList.add('d-none');
      document.getElementById('supportSuccess').classList.remove('d-none');
      document.getElementById('supportFooter').classList.add('d-none');
    } else {
      alertEl.className = 'alert alert-danger';
      const msg = (data && data.errors) ? data.errors.join(' ')
                : data ? `Server error (${response.status})`
                : `Unexpected response (${response.status}): ${raw.substring(0, 120)}`;
      alertEl.textContent = msg;
      resetBtn();
    }
  } catch (e) {
    alertEl.className = 'alert alert-danger';
    alertEl.textContent = 'Could not reach server. Please try again.';
    resetBtn();
  }
});
</script>

<%- include('partials/scripts') %>
