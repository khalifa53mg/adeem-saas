<%- include('../partials/head') %>
<% const isAr = (locals.lang || 'en') === 'ar'; %>
<div class="app-wrapper">
  <%- include('../partials/sidebar') %>

  <div class="main-content">
    <div class="topbar">
      <span class="topbar-title"><i class="bi bi-people me-2"></i><%= isAr ? 'المستأجرون' : 'Tenants' %></span>
      <div class="topbar-actions">
        <a href="/tenants/new" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg"></i> <%= isAr ? 'إضافة مستأجر' : 'Add Tenant' %></a>
      </div>
    </div>

    <div class="page-body">
      <% if (flash) { %>
      <div class="alert alert-<%= flash.type %> mb-3" data-autohide><%= flash.msg %></div>
      <% } %>

      <!-- Filter bar -->
      <form method="GET" action="/tenants" class="filter-bar">
        <div class="flex-fill" style="min-width:200px;">
          <label class="form-label mb-1"><%= isAr ? 'بحث' : 'Search' %></label>
          <input type="text" name="search" class="form-control" placeholder="<%= isAr ? 'الاسم، الهاتف…' : 'Name, phone…' %>" value="<%= search %>">
        </div>
        <div style="min-width:140px;">
          <label class="form-label mb-1"><%= isAr ? 'الحالة' : 'Status' %></label>
          <select name="status" class="form-select">
            <option value=""><%= isAr ? 'الكل' : 'All' %></option>
            <option value="active" <%= statusFilter === 'active' ? 'selected' : '' %>><%= isAr ? 'نشط' : 'Active' %></option>
            <option value="past"   <%= statusFilter === 'past'   ? 'selected' : '' %>><%= isAr ? 'سابق' : 'Past' %></option>
          </select>
        </div>
        <div class="d-flex align-items-end gap-2">
          <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-search"></i> <%= isAr ? 'تصفية' : 'Filter' %></button>
          <a href="/tenants" class="btn btn-outline-secondary btn-sm"><%= isAr ? 'إعادة تعيين' : 'Reset' %></a>
        </div>
      </form>

      <!-- Table -->
      <div class="card">
        <% if (tenants.length === 0) { %>
        <div class="empty-state">
          <div class="empty-icon">👤</div>
          <h6><%= isAr ? 'لا يوجد مستأجرون' : 'No Tenants Found' %></h6>
          <p><% if (search || statusFilter) { %><%= isAr ? 'لا يوجد مستأجرون يطابقون المرشحات.' : 'No tenants match your filters.' %> <a href="/tenants"><%= isAr ? 'مسح' : 'Clear' %></a><% } else { %><%= isAr ? 'أضف مستأجرك الأول للبدء.' : 'Add your first tenant to get started.' %><% } %></p>
          <a href="/tenants/new" class="btn btn-primary btn-sm mt-2"><i class="bi bi-plus-lg"></i> <%= isAr ? 'إضافة مستأجر' : 'Add Tenant' %></a>
        </div>
        <% } else { %>
        <div class="table-responsive">
          <table class="table mb-0">
            <thead>
              <tr>
                <th><%= isAr ? 'الاسم' : 'Name' %></th>
                <th><%= isAr ? 'الهاتف' : 'Phone' %></th>
                <th><%= isAr ? 'الحالة' : 'Status' %></th>
                <th><%= isAr ? 'الوحدات النشطة' : 'Active Units' %></th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% tenants.forEach(t => { %>
              <tr>
                <td>
                  <a href="/tenants/<%= t.id %>" class="fw-600 text-primary-c text-decoration-none"><%= t.full_name %></a>
                  <% if (t.address) { %><div class="text-dim" style="font-size:11.5px;"><%= t.address %></div><% } %>
                </td>
                <td><%= t.tel || '—' %></td>
                <td><span class="badge badge-<%= t.status %>"><%= isAr ? (t.status === 'active' ? 'نشط' : 'سابق') : t.status %></span></td>
                <td>
                  <% if (t.active_units > 0) { %>
                  <span class="badge badge-rented"><%= t.active_units %> <%= isAr ? (t.active_units > 1 ? 'وحدات' : 'وحدة') : ('unit' + (t.active_units > 1 ? 's' : '')) %></span>
                  <% } else { %>
                  <span class="text-dim">—</span>
                  <% } %>
                </td>
                <td class="text-end">
                  <a href="/tenants/<%= t.id %>" class="btn btn-outline-secondary btn-sm"><%= isAr ? 'عرض' : 'View' %></a>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/scripts') %>
