<%- include('../partials/head') %>
<div class="app-wrapper">
  <%- include('../partials/sidebar') %>

  <div class="main-content">
    <div class="topbar">
      <span class="topbar-title">
        <a href="/tenants" class="text-muted text-decoration-none"><i class="bi bi-people"></i> Tenants</a>
        <i class="bi bi-chevron-right mx-2 text-dim" style="font-size:11px;"></i>
        <%= tenant ? 'Edit Tenant' : 'New Tenant' %>
      </span>
    </div>

    <div class="page-body">
      <div class="card" style="max-width:560px;">
        <div class="card-header"><%= tenant ? 'Edit Tenant' : 'Add New Tenant' %></div>
        <div class="card-body">
          <% if (errors.length) { %>
          <div class="alert alert-danger mb-3">
            <% errors.forEach(e => { %><div><i class="bi bi-exclamation-circle me-1"></i><%= e %></div><% }) %>
          </div>
          <% } %>

          <form action="<%= tenant ? '/tenants/' + tenant.id + '/edit' : '/tenants' %>" method="POST">
            <div class="mb-3">
              <label class="form-label">Full Name <span class="text-danger">*</span></label>
              <input type="text" name="full_name" class="form-control" value="<%= tenant ? tenant.full_name : '' %>" required placeholder="Tenant full name">
            </div>
            <div class="row g-3 mb-3">
              <div class="col-6">
                <label class="form-label">Phone</label>
                <input type="text" name="tel" class="form-control" value="<%= tenant ? tenant.tel : '' %>" placeholder="+973 …">
              </div>
              <div class="col-6">
                <label class="form-label">Fax</label>
                <input type="text" name="fax" class="form-control" value="<%= tenant ? tenant.fax : '' %>" placeholder="Fax number">
              </div>
            </div>
            <div class="row g-3 mb-3">
              <div class="col-6">
                <label class="form-label">P.O. Box</label>
                <input type="text" name="po_box" class="form-control" value="<%= tenant ? tenant.po_box : '' %>" placeholder="P.O. Box">
              </div>
              <div class="col-6">
                <label class="form-label">Status</label>
                <select name="status" class="form-select">
                  <option value="active" <%= (!tenant || tenant.status === 'active') ? 'selected' : '' %>>Active</option>
                  <option value="past"   <%= (tenant && tenant.status === 'past')   ? 'selected' : '' %>>Past</option>
                </select>
              </div>
            </div>
            <div class="mb-4">
              <label class="form-label">Address</label>
              <textarea name="address" class="form-control" rows="2" placeholder="Full address"><%= tenant ? tenant.address : '' %></textarea>
            </div>
            <div class="d-flex gap-2">
              <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg"></i> <%= tenant ? 'Save Changes' : 'Create Tenant' %>
              </button>
              <a href="<%= tenant ? '/tenants/' + tenant.id : '/tenants' %>" class="btn btn-outline-secondary">Cancel</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/scripts') %>
