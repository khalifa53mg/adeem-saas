<%- include('partials/head') %>

<div class="login-page" style="min-height:100vh;overflow-y:auto;padding:2rem 0;">
  <div class="login-card" style="max-width:520px;width:100%;">
    <div class="login-logo">
      <div class="logo-icon">🏢</div>
      <h1>Adeem Real Estate</h1>
      <p>Register Your Company</p>
    </div>

    <% if (error) { %>
    <div class="alert alert-danger mb-3" role="alert">
      <i class="bi bi-exclamation-circle me-2"></i><%= error %>
    </div>
    <% } %>

    <form action="/register" method="POST" id="registerForm">

      <div class="mb-3">
        <label class="form-label fw-semibold">Company Name <span class="text-danger">*</span></label>
        <input type="text" name="company_name" class="form-control"
          value="<%= typeof values !== 'undefined' && values.company_name ? values.company_name : '' %>"
          placeholder="Acme Real Estate Ltd." required id="companyNameInput">
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">Company ID <span class="text-danger">*</span></label>
        <input type="text" name="slug" class="form-control" id="slugInput"
          value="<%= typeof values !== 'undefined' && values.slug ? values.slug : '' %>"
          placeholder="acme-real-estate" pattern="[a-z0-9\-]{3,30}" required
          autocomplete="off">
        <div class="form-text">3-30 characters: lowercase letters, numbers, hyphens only. This is your login ID.</div>
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <label class="form-label fw-semibold">Country <span class="text-danger">*</span></label>
          <select name="country" class="form-select" required id="countrySelect">
            <option value="">— Select Country —</option>
            <option value="Bahrain" <%= (typeof values !== 'undefined' && values.country === 'Bahrain') ? 'selected' : '' %>>Bahrain</option>
            <option value="Qatar" <%= (typeof values !== 'undefined' && values.country === 'Qatar') ? 'selected' : '' %>>Qatar</option>
            <option value="Oman" <%= (typeof values !== 'undefined' && values.country === 'Oman') ? 'selected' : '' %>>Oman</option>
            <option value="Kuwait" <%= (typeof values !== 'undefined' && values.country === 'Kuwait') ? 'selected' : '' %>>Kuwait</option>
          </select>
        </div>
        <div class="col-md-6 mb-3">
          <label class="form-label fw-semibold">Currency</label>
          <input type="text" id="currencyDisplay" class="form-control" readonly
            value="<%= typeof values !== 'undefined' && values.country ? ({Bahrain:'BHD – Bahraini Dinar',Qatar:'QAR – Qatari Riyal',Oman:'OMR – Omani Rial',Kuwait:'KWD – Kuwaiti Dinar'}[values.country] || '') : '' %>"
            placeholder="Auto-set from country" style="opacity:0.7;">
        </div>
      </div>

      <hr class="my-3">

      <div class="mb-3">
        <label class="form-label fw-semibold">Your Name <span class="text-danger">*</span></label>
        <input type="text" name="admin_name" class="form-control"
          value="<%= typeof values !== 'undefined' && values.admin_name ? values.admin_name : '' %>"
          placeholder="John Smith" required>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">Mobile <span class="text-danger">*</span></label>
        <input type="tel" name="mobile" class="form-control"
          value="<%= typeof values !== 'undefined' && values.mobile ? values.mobile : '' %>"
          placeholder="+973 3300 0000" required>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
        <input type="email" name="admin_email" class="form-control"
          value="<%= typeof values !== 'undefined' && values.admin_email ? values.admin_email : '' %>"
          placeholder="john@example.com" required>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">Password <span class="text-danger">*</span></label>
        <input type="password" name="password" class="form-control"
          placeholder="At least 8 characters" minlength="8" required autocomplete="new-password">
      </div>

      <div class="mb-4">
        <label class="form-label fw-semibold">Confirm Password <span class="text-danger">*</span></label>
        <input type="password" name="confirm_password" class="form-control"
          placeholder="Repeat password" minlength="8" required autocomplete="new-password">
      </div>

      <button type="submit" class="btn btn-primary w-100">
        <i class="bi bi-building-add"></i> Create Account
      </button>
    </form>

    <div class="mt-3 text-center" style="font-size:0.875rem;">
      <span style="opacity:0.6;">Already have an account?</span>
      <a href="/login" class="ms-1">Sign in</a>
    </div>
  </div>
</div>

<script>
  // Auto-derive slug from company name
  const companyInput = document.getElementById('companyNameInput');
  const slugInput = document.getElementById('slugInput');
  let slugEdited = slugInput.value.length > 0;

  slugInput.addEventListener('input', () => { slugEdited = true; });

  companyInput.addEventListener('input', () => {
    if (!slugEdited) {
      const derived = companyInput.value
        .toLowerCase()
        .trim()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-+|-+$/g, '')
        .slice(0, 30);
      slugInput.value = derived;
    }
  });

  // Auto-set currency from country
  const countryCurrency = {
    'Bahrain': 'BHD – Bahraini Dinar',
    'Qatar':   'QAR – Qatari Riyal',
    'Oman':    'OMR – Omani Rial',
    'Kuwait':  'KWD – Kuwaiti Dinar',
  };
  const countrySelect = document.getElementById('countrySelect');
  const currencyDisplay = document.getElementById('currencyDisplay');

  countrySelect.addEventListener('change', () => {
    currencyDisplay.value = countryCurrency[countrySelect.value] || '';
  });
</script>

<%- include('partials/scripts') %>
