<%- include('partials/head') %>

<div class="login-page" style="min-height:100vh;overflow-y:auto;padding:2rem 0;" dir="rtl">
  <div class="login-card" style="max-width:480px;width:100%;">
    <div class="login-logo">
      <div class="logo-icon">🏢</div>
      <h1>أديـــم</h1>
      <p>سجّل شركتك وابدأ مجانًا</p>
    </div>

    <% if (error) { %>
    <div class="alert alert-danger mb-3" role="alert">
      <i class="bi bi-exclamation-circle me-2"></i><%= error %>
    </div>
    <% } %>

    <form action="/register" method="POST" id="registerForm">

      <!-- Hidden: auto-generated from email -->
      <input type="hidden" name="company_name" id="companyNameInput">
      <input type="hidden" name="slug" id="slugInput">
      <!-- Hidden: auto-set from country -->
      <input type="hidden" name="currency" id="currencyInput">

      <div class="mb-3">
        <label class="form-label fw-semibold">الدولة <span class="text-danger">*</span></label>
        <select name="country" class="form-select" required id="countrySelect">
          <option value="">— اختر الدولة —</option>
          <option value="Bahrain" <%= (typeof values !== 'undefined' && values.country === 'Bahrain') ? 'selected' : '' %>>البحرين</option>
          <option value="Qatar"   <%= (typeof values !== 'undefined' && values.country === 'Qatar')   ? 'selected' : '' %>>قطر</option>
          <option value="Oman"    <%= (typeof values !== 'undefined' && values.country === 'Oman')    ? 'selected' : '' %>>عُمان</option>
          <option value="Kuwait"  <%= (typeof values !== 'undefined' && values.country === 'Kuwait')  ? 'selected' : '' %>>الكويت</option>
        </select>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">اسمك <span class="text-danger">*</span></label>
        <input type="text" name="admin_name" class="form-control"
          value="<%= typeof values !== 'undefined' && values.admin_name ? values.admin_name : '' %>"
          placeholder="محمد أحمد" required>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">رقم الجوال <span class="text-danger">*</span></label>
        <input type="tel" name="mobile" class="form-control"
          value="<%= typeof values !== 'undefined' && values.mobile ? values.mobile : '' %>"
          placeholder="+973 3300 0000" required>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">البريد الإلكتروني <span class="text-danger">*</span></label>
        <input type="email" name="admin_email" class="form-control" id="emailInput"
          value="<%= typeof values !== 'undefined' && values.admin_email ? values.admin_email : '' %>"
          placeholder="you@example.com" required>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">كلمة المرور <span class="text-danger">*</span></label>
        <input type="password" name="password" class="form-control"
          placeholder="٨ أحرف على الأقل" minlength="8" required autocomplete="new-password">
      </div>

      <div class="mb-4">
        <label class="form-label fw-semibold">تأكيد كلمة المرور <span class="text-danger">*</span></label>
        <input type="password" name="confirm_password" class="form-control"
          placeholder="أعد كتابة كلمة المرور" minlength="8" required autocomplete="new-password">
      </div>

      <button type="submit" class="btn btn-primary w-100">
        <i class="bi bi-building-add"></i> إنشاء الحساب
      </button>
    </form>

    <div class="mt-3 text-center" style="font-size:0.875rem;">
      <span style="opacity:0.6;">لديك حساب بالفعل؟</span>
      <a href="/login" class="ms-1">تسجيل الدخول</a>
    </div>
  </div>
</div>

<script>
  const countryCurrency = {
    'Bahrain': 'BHD',
    'Qatar':   'QAR',
    'Oman':    'OMR',
    'Kuwait':  'KWD',
  };

  const countrySelect  = document.getElementById('countrySelect');
  const currencyInput  = document.getElementById('currencyInput');
  const emailInput     = document.getElementById('emailInput');
  const slugInput      = document.getElementById('slugInput');
  const companyInput   = document.getElementById('companyNameInput');

  // Auto-set hidden currency from country
  countrySelect.addEventListener('change', () => {
    currencyInput.value = countryCurrency[countrySelect.value] || '';
  });
  // Set on load if value already present (validation re-render)
  if (countrySelect.value) {
    currencyInput.value = countryCurrency[countrySelect.value] || '';
  }

  // Auto-generate slug and company name from email
  function deriveFromEmail(email) {
    const prefix = email.split('@')[0] || '';
    // slug: lowercase alphanumeric + hyphens
    const slug = prefix
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '')
      .slice(0, 30) || 'company';
    // company name: capitalize each word separated by dots/hyphens/underscores
    const name = prefix
      .replace(/[.\-_]+/g, ' ')
      .replace(/\b\w/g, c => c.toUpperCase())
      .trim() || 'My Company';
    return { slug, name };
  }

  emailInput.addEventListener('input', () => {
    const { slug, name } = deriveFromEmail(emailInput.value);
    slugInput.value    = slug;
    companyInput.value = name;
  });

  // Run on load in case of pre-filled value
  if (emailInput.value) {
    const { slug, name } = deriveFromEmail(emailInput.value);
    slugInput.value    = slug;
    companyInput.value = name;
  }
</script>

<%- include('partials/scripts') %>
