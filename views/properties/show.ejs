<%- include('../partials/head') %>
<% const isAr = (locals.lang || 'en') === 'ar'; %>
<div class="app-wrapper">
  <%- include('../partials/sidebar') %>

  <div class="main-content">
    <div class="topbar">
      <span class="topbar-title">
        <a href="/properties" class="text-muted text-decoration-none"><i class="bi bi-buildings"></i> <%= isAr ? 'العقارات' : 'Properties' %></a>
        <i class="bi bi-chevron-right mx-2 text-dim" style="font-size:11px;"></i>
        <%= property.name %>
      </span>
      <div class="topbar-actions">
        <% if (locals.user && user.role === 'admin') { %>
        <a href="/units/new?property_id=<%= property.id %>" class="btn btn-primary btn-sm">
          <i class="bi bi-plus-lg"></i> <%= isAr ? 'إضافة وحدة' : 'Add Unit' %>
        </a>
        <a href="/properties/<%= property.id %>/edit" class="btn btn-warning btn-sm">
          <i class="bi bi-pencil"></i> <%= isAr ? 'تعديل' : 'Edit' %>
        </a>
        <button class="btn btn-outline-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#archiveModal">
          <i class="bi bi-archive"></i>
        </button>
        <% } %>
      </div>
    </div>

    <div class="page-body">
      <!-- Flash -->
      <% if (flash) { %>
      <div class="alert alert-<%= flash.type %> mb-3" data-autohide><%= flash.msg %></div>
      <% } %>

      <!-- Property Info -->
      <div class="card mb-4">
        <div class="card-body">
          <div class="d-flex align-items-start justify-content-between mb-3">
            <div>
              <h5 class="mb-1 fw-700"><%= property.name %></h5>
              <% if (property.location) { %>
              <div class="text-muted" style="font-size:13px;"><i class="bi bi-geo-alt me-1"></i><%= property.location %></div>
              <% } %>
            </div>
            <span class="badge badge-<%= property.status %>"><%= isAr ? (property.status === 'active' ? 'نشط' : 'محظور') : property.status %></span>
          </div>
          <div class="info-grid">
            <% if (property.address) { %>
            <div class="info-item">
              <div class="info-label"><%= isAr ? 'العنوان' : 'Address' %></div>
              <div class="info-value"><%= property.address %></div>
            </div>
            <% } %>
            <%
              const _physical = units.filter(u => !virtualUnitIds.includes(u.id));
              const _rentedPhysical = _physical.filter(u => {
                if (u.status === 'rented') return true;
                if (u.group_virtual_id) {
                  const virt = units.find(v => v.id === u.group_virtual_id);
                  return virt && virt.status === 'rented';
                }
                return false;
              });
            %>
            <div class="info-item">
              <div class="info-label"><%= isAr ? 'إجمالي الوحدات' : 'Total Units' %></div>
              <div class="info-value"><%= _physical.length %></div>
            </div>
            <div class="info-item">
              <div class="info-label"><%= isAr ? 'مستأجرة' : 'Rented' %></div>
              <div class="info-value text-success"><%= _rentedPhysical.length %></div>
            </div>
            <div class="info-item">
              <div class="info-label"><%= isAr ? 'شاغرة' : 'Vacant' %></div>
              <div class="info-value text-warning"><%= _physical.length - _rentedPhysical.length %></div>
            </div>
            <% if (mergeGroupCount > 0) { %>
            <div class="info-item">
              <div class="info-label"><%= isAr ? 'مجموعات الدمج' : 'Merge Groups' %></div>
              <div class="info-value" style="color:#a855f7;"><i class="bi bi-union me-1"></i><%= mergeGroupCount %></div>
            </div>
            <% } %>
            <div class="info-item">
              <div class="info-label"><%= isAr ? 'تاريخ الإنشاء' : 'Created' %></div>
              <div class="info-value"><%= new Date(property.created_at).toLocaleDateString() %></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Units table -->
      <div class="card" id="unitsCard">
        <div class="card-header">
          <%= isAr ? 'الوحدات' : 'Units' %>
          <% if (locals.user && user.role === 'admin') { %>
          <!-- Merge toolbar (hidden until 2+ checkboxes checked) -->
          <span id="mergeToolbar" class="d-none gap-2 align-items-center me-2">
            <span id="mergeCount" class="text-muted" style="font-size:12px;"></span>
            <a id="mergeBtn" href="#" class="btn btn-sm" style="background:rgba(168,85,247,0.15);color:#a855f7;border:1px solid rgba(168,85,247,0.3);">
              <i class="bi bi-union"></i> <%= isAr ? 'دمج المحدد' : 'Merge Selected' %>
            </a>
          </span>
          <a href="/units/new?property_id=<%= property.id %>" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg"></i> <%= isAr ? 'إضافة وحدة' : 'Add Unit' %>
          </a>
          <% } %>
        </div>
        <% if (units.length === 0) { %>
        <div class="empty-state">
          <div class="empty-icon">🏠</div>
          <h6><%= isAr ? 'لا توجد وحدات بعد' : 'No Units Yet' %></h6>
          <p><%= isAr ? 'أضف وحدات لبدء تتبع المستأجرين والمدفوعات.' : 'Add units to start tracking tenants and payments.' %></p>
          <% if (locals.user && user.role === 'admin') { %>
          <a href="/units/new?property_id=<%= property.id %>" class="btn btn-primary btn-sm mt-2">
            <i class="bi bi-plus-lg"></i> <%= isAr ? 'إضافة وحدة' : 'Add Unit' %>
          </a>
          <% } %>
        </div>
        <% } else { %>
        <div class="table-responsive">
          <table class="table mb-0">
            <thead>
              <tr>
                <% if (locals.user && user.role === 'admin') { %>
                <th style="width:36px;"></th>
                <% } %>
                <th><%= isAr ? 'الوحدة' : 'Unit' %></th>
                <th><%= isAr ? 'الإيجار' : 'Rent' %> (<%= currencyLabel %>/mo)</th>
                <th><%= isAr ? 'الحالة' : 'Status' %></th>
                <th><%= isAr ? 'المستأجر' : 'Tenant' %></th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% units.forEach(u => { %>
              <%
                const isGroupUnit = virtualUnitIds.includes(u.id);
                const isMergedMember = !!u.group_id;
              %>
              <tr>
                <% if (locals.user && user.role === 'admin') { %>
                <td>
                  <% if (!isGroupUnit && !isMergedMember) { %>
                  <input type="checkbox" class="unit-checkbox form-check-input" value="<%= u.id %>" style="cursor:pointer;">
                  <% } %>
                </td>
                <% } %>
                <td>
                  <a href="/units/<%= u.id %>" class="fw-600 text-primary-c text-decoration-none">
                    <%= u.unit_number || u.name %>
                  </a>
                  <% if (isGroupUnit) { %>
                  <span class="badge badge-group ms-1"><i class="bi bi-union me-1"></i><%= isAr ? 'مجموعة' : 'GROUP' %></span>
                  <% } else if (isMergedMember) { %>
                  <span class="badge badge-merged ms-1"><%= isAr ? 'مدمج' : 'Merged' %></span>
                  <div class="text-dim" style="font-size:11px;"><%= isAr ? 'جزء من' : 'Part of' %> <a href="/units/<%= u.group_virtual_id %>" class="text-decoration-none" style="color:inherit;"><%= u.group_name %></a></div>
                  <% } else if (u.address) { %>
                  <div class="text-dim" style="font-size:11.5px;"><%= u.address %></div>
                  <% } %>
                </td>
                <td class="fw-600"><%= u.monthly_rent_bhd.toFixed(currencyDecimals) %></td>
                <td>
                  <% if (isGroupUnit) { %>
                  <span class="badge badge-group"><%= u.status %></span>
                  <% } else if (isMergedMember) { %>
                  <span class="badge badge-merged"><%= isAr ? 'مدمج' : 'merged' %></span>
                  <% } else { %>
                  <span class="badge badge-<%= u.status %>"><%= isAr ? (u.status === 'rented' ? 'مستأجرة' : u.status === 'new' ? 'شاغرة' : 'محظور') : u.status %></span>
                  <% } %>
                </td>
                <td>
                  <% if (u.tenant_name) { %>
                  <a href="/tenants/<%= u.tenant_id %>" class="text-decoration-none"><%= u.tenant_name %></a>
                  <% } else { %>
                  <span class="text-dim">—</span>
                  <% } %>
                </td>
                <td class="text-end">
                  <a href="/units/<%= u.id %>" class="btn btn-primary btn-sm"><%= isAr ? 'عرض' : 'View' %></a>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Archive Modal -->
<% if (locals.user && user.role === 'admin') { %>
<div class="modal fade" id="archiveModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-archive me-2"></i><%= isAr ? 'أرشفة العقار' : 'Archive Property' %></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" style="font-size:13.5px;">
        <%= isAr ? 'هل أنت متأكد من أرشفة' : 'Are you sure you want to archive' %> <strong><%= property.name %></strong>?
        <%= isAr ? 'ستُؤرشف جميع الوحدات أيضاً. لا يمكن التراجع عن هذا الإجراء.' : 'All units will also be archived. This action cannot be undone from the UI.' %>
      </div>
      <div class="modal-footer">
        <button class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal"><%= isAr ? 'إلغاء' : 'Cancel' %></button>
        <form action="/properties/<%= property.id %>/archive" method="POST">
          <button type="submit" class="btn btn-danger btn-sm">
            <i class="bi bi-archive"></i> <%= isAr ? 'أرشفة' : 'Archive' %>
          </button>
        </form>
      </div>
    </div>
  </div>
</div>
<% } %>

<% if (locals.user && user.role === 'admin') { %>
<script>
(function() {
  const checkboxes = document.querySelectorAll('.unit-checkbox');
  const toolbar = document.getElementById('mergeToolbar');
  const countEl = document.getElementById('mergeCount');
  const mergeBtn = document.getElementById('mergeBtn');

  if (!checkboxes.length || !toolbar) return;

  function updateToolbar() {
    const checked = [...checkboxes].filter(c => c.checked);
    if (checked.length >= 2) {
      toolbar.classList.remove('d-none');
      toolbar.classList.add('d-inline-flex');
      countEl.textContent = checked.length + ' selected';
      mergeBtn.href = '/units/merge?ids=' + checked.map(c => c.value).join(',');
    } else {
      toolbar.classList.add('d-none');
      toolbar.classList.remove('d-inline-flex');
    }
  }

  checkboxes.forEach(cb => cb.addEventListener('change', updateToolbar));
})();
</script>
<% } %>
<%- include('../partials/scripts') %>
