<%- include('../partials/head') %>
<% const isAr = (locals.lang || 'en') === 'ar'; %>
<div class="app-wrapper">
  <%- include('../partials/sidebar') %>

  <div class="main-content">
    <div class="topbar">
      <span class="topbar-title">
        <a href="/properties" class="text-muted text-decoration-none"><i class="bi bi-buildings"></i></a>
        <i class="bi bi-chevron-right mx-2 text-dim" style="font-size:11px;"></i>
        <a href="/properties/<%= unit.property_id %>" class="text-muted text-decoration-none"><%= unit.property_name %></a>
        <i class="bi bi-chevron-right mx-2 text-dim" style="font-size:11px;"></i>
        <a href="/units/<%= unit.id %>" class="text-muted text-decoration-none"><%= unit.unit_number || unit.name %></a>
        <i class="bi bi-chevron-right mx-2 text-dim" style="font-size:11px;"></i>
        <%= isAr ? 'تعديل التعيين' : 'Edit Assignment' %>
      </span>
    </div>

    <div class="page-body">
      <% if (flash) { %>
      <div class="alert alert-<%= flash.type %> mb-3" data-autohide><%= flash.msg %></div>
      <% } %>

      <% if (errors.length) { %>
      <div class="alert alert-danger mb-3">
        <% errors.forEach(e => { %><div><i class="bi bi-exclamation-circle me-1"></i><%= e %></div><% }) %>
      </div>
      <% } %>

      <% if (assignment.is_current) { %>
      <div class="alert alert-warning mb-3" style="font-size:13px;">
        <i class="bi bi-exclamation-triangle me-1"></i>
        <%= isAr ? 'هذا هو التعيين النشط الحالي. ستؤثر التغييرات على معلومات المستأجر الحالي.' : 'This is the currently active assignment. Changes will affect the current tenant information.' %>
      </div>
      <% } %>

      <form action="/units/<%= unit.id %>/assignments/<%= assignment.id %>/edit" method="POST">
        <div class="card" style="max-width:560px;">
          <div class="card-header"><%= isAr ? 'تعديل التعيين' : 'Edit Assignment' %></div>
          <div class="card-body">
            <div class="mb-3">
              <label class="form-label"><%= isAr ? 'المستأجر' : 'Tenant' %> <span class="text-danger">*</span></label>
              <select name="tenant_id" class="form-select" required>
                <option value=""><%= isAr ? 'اختر مستأجراً…' : 'Select tenant…' %></option>
                <% allTenants.forEach(t => { %>
                <option value="<%= t.id %>" <%= String(assignment.tenant_id) === String(t.id) ? 'selected' : '' %>>
                  <%= t.full_name %><%= t.tel ? ' — ' + t.tel : '' %>
                </option>
                <% }) %>
              </select>
            </div>

            <div class="row g-3">
              <div class="col-6">
                <label class="form-label"><%= isAr ? 'بداية العقد' : 'Lease Start' %> <span class="text-danger">*</span></label>
                <input type="date" name="lease_start" class="form-control" required
                  value="<%= assignment.lease_start %>">
              </div>
              <div class="col-6">
                <label class="form-label"><%= isAr ? 'نهاية العقد' : 'Lease End' %></label>
                <input type="date" name="lease_end" class="form-control"
                  value="<%= assignment.lease_end || '' %>">
                <div class="form-text"><%= isAr ? 'اتركه فارغاً للعقد المفتوح' : 'Leave blank for open-ended' %></div>
              </div>
            </div>
          </div>
          <div class="card-footer d-flex gap-2">
            <button type="submit" class="btn btn-primary btn-sm">
              <i class="bi bi-check-lg"></i> <%= isAr ? 'حفظ التغييرات' : 'Save Changes' %>
            </button>
            <a href="/units/<%= unit.id %>" class="btn btn-outline-secondary btn-sm">
              <%= isAr ? 'إلغاء' : 'Cancel' %>
            </a>
          </div>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/scripts') %>
