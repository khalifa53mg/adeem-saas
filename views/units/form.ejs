<%- include('../partials/head') %>
<div class="app-wrapper">
  <%- include('../partials/sidebar') %>

  <div class="main-content">
    <div class="topbar">
      <span class="topbar-title">
        <a href="/properties" class="text-muted text-decoration-none"><i class="bi bi-buildings"></i> Properties</a>
        <i class="bi bi-chevron-right mx-2 text-dim" style="font-size:11px;"></i>
        <%= unit ? 'Edit Unit' : 'New Unit' %>
      </span>
    </div>

    <div class="page-body">
      <div class="card" style="max-width:560px;">
        <div class="card-header"><%= unit ? 'Edit Unit' : 'Add New Unit' %></div>
        <div class="card-body">
          <% if (errors.length) { %>
          <div class="alert alert-danger mb-3">
            <% errors.forEach(e => { %><div><i class="bi bi-exclamation-circle me-1"></i><%= e %></div><% }) %>
          </div>
          <% } %>

          <form action="<%= unit ? '/units/' + unit.id + '/edit' : '/units' %>" method="POST">
            <div class="mb-3">
              <label class="form-label">Property <span class="text-danger">*</span></label>
              <select name="property_id" class="form-select" required <%= unit ? 'disabled' : '' %>>
                <option value="">Select property…</option>
                <% properties.forEach(p => { %>
                <option value="<%= p.id %>" <%= (String(selectedPropertyId) === String(p.id)) ? 'selected' : '' %>><%= p.name %></option>
                <% }) %>
              </select>
              <% if (unit) { %>
              <input type="hidden" name="property_id" value="<%= unit.property_id %>">
              <% } %>
            </div>
            <div class="mb-3">
              <label class="form-label">Unit No. <span class="text-danger">*</span></label>
              <input type="text" name="unit_number" class="form-control" value="<%= unit ? unit.unit_number : '' %>" required placeholder="e.g. 101">
            </div>
            <div class="mb-3">
              <label class="form-label">Address</label>
              <input type="text" name="address" class="form-control" value="<%= unit ? unit.address : '' %>" placeholder="Floor / block / location details">
            </div>
            <div class="row g-3 mb-3">
              <div class="col-6">
                <label class="form-label">Monthly Rent (BD) <span class="text-danger">*</span></label>
                <input type="number" name="monthly_rent_bhd" class="form-control" step="0.001" min="0"
                  value="<%= unit ? unit.monthly_rent_bhd : '' %>" required placeholder="0.000">
              </div>
              <div class="col-6">
                <label class="form-label">Status <span class="text-danger">*</span></label>
                <select name="status" class="form-select" required>
                  <option value="new"     <%= (!unit || unit.status === 'new')     ? 'selected' : '' %>>Vacant</option>
                  <option value="rented"  <%= (unit && unit.status === 'rented')   ? 'selected' : '' %>>Rented</option>
                  <option value="blocked" <%= (unit && unit.status === 'blocked')  ? 'selected' : '' %>>Blocked</option>
                </select>
              </div>
            </div>
            <div class="d-flex gap-2">
              <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg"></i> <%= unit ? 'Save Changes' : 'Create Unit' %>
              </button>
              <% if (unit) { %>
              <a href="/units/<%= unit.id %>" class="btn btn-outline-secondary">Cancel</a>
              <% } else { %>
              <a href="<%= selectedPropertyId ? '/properties/' + selectedPropertyId : '/properties' %>" class="btn btn-outline-secondary">Cancel</a>
              <% } %>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/scripts') %>
