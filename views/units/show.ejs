<%- include('../partials/head') %>
<% const isAr = (locals.lang || 'en') === 'ar'; %>
<div class="app-wrapper">
  <%- include('../partials/sidebar') %>

  <div class="main-content">
    <div class="topbar">
      <span class="topbar-title">
        <a href="/properties" class="text-muted text-decoration-none"><i class="bi bi-buildings"></i></a>
        <i class="bi bi-chevron-right mx-2 text-dim" style="font-size:11px;"></i>
        <a href="/properties/<%= unit.property_id %>" class="text-muted text-decoration-none"><%= unit.property_name %></a>
        <i class="bi bi-chevron-right mx-2 text-dim" style="font-size:11px;"></i>
        <%= unit.unit_number || unit.name %>
      </span>
      <div class="topbar-actions">
        <% if (locals.user && user.role === 'admin') { %>
        <a href="/units/<%= unit.id %>/edit" class="btn btn-outline-secondary btn-sm"><i class="bi bi-pencil"></i> <%= isAr ? 'تعديل' : 'Edit' %></a>
        <% if (!currentTenant) { %>
        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#assignModal">
          <i class="bi bi-person-plus"></i> <%= isAr ? 'تعيين مستأجر' : 'Assign Tenant' %>
        </button>
        <% } else { %>
        <button class="btn btn-outline-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#vacateModal">
          <i class="bi bi-person-dash"></i> <%= isAr ? 'إخلاء' : 'Vacate' %>
        </button>
        <% } %>
        <button class="btn btn-outline-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#archiveModal">
          <i class="bi bi-archive"></i>
        </button>
        <% } %>
      </div>
    </div>

    <div class="page-body">
      <% if (flash) { %>
      <div class="alert alert-<%= flash.type %> mb-3" data-autohide><%= flash.msg %></div>
      <% } %>

      <%# ── Banner: this unit is a virtual GROUP unit ── %>
      <% if (groupInfo) { %>
      <div class="card mb-3" style="border-left:3px solid #a855f7;">
        <div class="card-body py-3">
          <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
              <span class="badge badge-group me-2"><i class="bi bi-union me-1"></i><%= isAr ? 'مجموعة مدمجة' : 'MERGED GROUP' %></span>
              <span class="fw-600" style="font-size:14px;"><%= isAr ? 'هذه وحدة مجموعة افتراضية تشمل:' : 'This is a virtual group unit comprising:' %></span>
              <div class="mt-2 d-flex flex-wrap gap-2">
                <% groupMembers.forEach(m => { %>
                <a href="/units/<%= m.id %>" class="badge badge-merged text-decoration-none" style="font-size:12px;padding:5px 10px;">
                  <%= m.unit_number || m.name %>
                  <span class="text-dim ms-1"><%= currencyLabel %> <%= m.monthly_rent_bhd.toFixed(3) %></span>
                </a>
                <% }) %>
              </div>
            </div>
            <% if (locals.user && user.role === 'admin') { %>
            <% const canDissolve = !currentTenant; %>
            <% if (canDissolve) { %>
            <button class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#dissolveModal">
              <i class="bi bi-x-circle me-1"></i><%= isAr ? 'حل المجموعة' : 'Dissolve Group' %>
            </button>
            <% } else { %>
            <span class="text-dim" style="font-size:12px;"><i class="bi bi-lock me-1"></i><%= isAr ? 'أخلِ المستأجر لحل المجموعة' : 'Vacate tenant to dissolve' %></span>
            <% } %>
            <% } %>
          </div>
        </div>
      </div>
      <% } %>

      <%# ── Banner: this unit is a constituent (merged member) ── %>
      <% if (memberOfGroup) { %>
      <div class="card mb-3" style="border-left:3px solid #14b8a6;">
        <div class="card-body py-3">
          <span class="badge badge-merged me-2"><%= isAr ? 'مدمج' : 'Merged' %></span>
          <span style="font-size:13.5px;"><%= isAr ? 'هذه الوحدة جزء من مجموعة الدمج' : 'This unit is part of merge group' %>
            <a href="/units/<%= memberOfGroup.virtual_id %>" class="fw-600 text-decoration-none" style="color:#14b8a6;"><%= memberOfGroup.group_name %></a>.
            <%= isAr ? 'يُدار تعيين المستأجر والمدفوعات على وحدة المجموعة.' : 'Tenant assignment and payments are managed on the group unit.' %>
          </span>
        </div>
      </div>
      <% } %>

      <div class="row g-3 mb-3">
        <!-- Unit Info -->
        <div class="col-12 col-lg-6">
          <div class="card h-100">
            <div class="card-header"><%= isAr ? 'تفاصيل الوحدة' : 'Unit Details' %></div>
            <div class="card-body">
              <div class="info-grid">
                <div class="info-item">
                  <div class="info-label"><%= isAr ? 'رقم الوحدة' : 'Unit Number' %></div>
                  <div class="info-value"><%= unit.unit_number || unit.name || '—' %></div>
                </div>
                <div class="info-item">
                  <div class="info-label"><%= isAr ? 'العقار' : 'Property' %></div>
                  <div class="info-value">
                    <a href="/properties/<%= unit.property_id %>" class="text-decoration-none"><%= unit.property_name %></a>
                  </div>
                </div>
                <div class="info-item">
                  <div class="info-label"><%= isAr ? 'الإيجار الشهري' : 'Monthly Rent' %></div>
                  <div class="info-value fw-700 text-success"><%= currencyLabel %> <%= unit.monthly_rent_bhd.toFixed(3) %></div>
                </div>
                <div class="info-item">
                  <div class="info-label"><%= isAr ? 'الحالة' : 'Status' %></div>
                  <div class="info-value">
                    <span class="badge badge-<%= unit.status %>">
                      <%= isAr ? (unit.status === 'rented' ? 'مستأجرة' : unit.status === 'new' ? 'شاغرة' : 'محظور') : unit.status %>
                    </span>
                  </div>
                </div>
                <% if (unit.address) { %>
                <div class="info-item">
                  <div class="info-label"><%= isAr ? 'العنوان' : 'Address' %></div>
                  <div class="info-value"><%= unit.address %></div>
                </div>
                <% } %>
              </div>
            </div>
          </div>
        </div>

        <!-- Current Tenant -->
        <div class="col-12 col-lg-6">
          <div class="card h-100">
            <div class="card-header"><%= isAr ? 'المستأجر الحالي' : 'Current Tenant' %></div>
            <div class="card-body">
              <% if (currentTenant) { %>
              <div class="d-flex align-items-center gap-3 mb-3">
                <div class="user-avatar" style="width:44px;height:44px;font-size:17px;">
                  <%= currentTenant.full_name.charAt(0).toUpperCase() %>
                </div>
                <div>
                  <div class="fw-600" style="font-size:15px;">
                    <a href="/tenants/<%= currentTenant.id %>" class="text-decoration-none text-primary-c"><%= currentTenant.full_name %></a>
                  </div>
                  <% if (currentTenant.tel) { %>
                  <div class="text-muted" style="font-size:12.5px;"><i class="bi bi-telephone me-1"></i><%= currentTenant.tel %></div>
                  <% } %>
                </div>
              </div>
              <div class="info-grid">
                <div class="info-item">
                  <div class="info-label"><%= isAr ? 'بداية العقد' : 'Lease Start' %></div>
                  <div class="info-value"><%= currentTenant.lease_start %></div>
                </div>
                <div class="info-item">
                  <div class="info-label"><%= isAr ? 'نهاية العقد' : 'Lease End' %></div>
                  <div class="info-value"><%= currentTenant.lease_end || (isAr ? 'مفتوح' : 'Open-ended') %></div>
                </div>
              </div>
              <% if (locals.user && user.role === 'admin') { %>
              <div class="mt-3 d-flex gap-2 flex-wrap">
                <a href="/payments/new?unit_id=<%= unit.id %>" class="btn btn-primary btn-sm">
                  <i class="bi bi-cash-stack"></i> <%= isAr ? 'تسجيل دفعة' : 'Record Payment' %>
                </a>
                <a href="/units/<%= unit.id %>/assignments/<%= currentTenant.lease_id %>/edit" class="btn btn-outline-secondary btn-sm">
                  <i class="bi bi-pencil"></i> <%= isAr ? 'تعديل التعيين' : 'Edit Assignment' %>
                </a>
                <button class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#vacateModal">
                  <i class="bi bi-person-dash"></i> <%= isAr ? 'إنهاء الإيجار' : 'End Lease' %>
                </button>
              </div>
              <% } %>
              <% } else { %>
              <div class="empty-state" style="padding:24px 0;">
                <div class="empty-icon">👤</div>
                <h6><%= isAr ? 'لا يوجد مستأجر نشط' : 'No Active Tenant' %></h6>
                <p style="font-size:12.5px;"><%= isAr ? 'هذه الوحدة شاغرة حالياً.' : 'This unit is currently vacant.' %></p>
                <% if (locals.user && user.role === 'admin') { %>
                <button class="btn btn-primary btn-sm mt-1" data-bs-toggle="modal" data-bs-target="#assignModal">
                  <i class="bi bi-person-plus"></i> <%= isAr ? 'تعيين مستأجر' : 'Assign Tenant' %>
                </button>
                <% } %>
              </div>
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <!-- Tenant History -->
      <% if (tenantHistory.length > 0) { %>
      <div class="card mb-3">
        <div class="card-header"><%= isAr ? 'سجل المستأجرين' : 'Tenant History' %></div>
        <div class="table-responsive">
          <table class="table mb-0">
            <thead>
              <tr>
                <th><%= isAr ? 'المستأجر' : 'Tenant' %></th>
                <th><%= isAr ? 'بداية العقد' : 'Lease Start' %></th>
                <th><%= isAr ? 'نهاية العقد' : 'Lease End' %></th>
                <th><%= isAr ? 'الحالة' : 'Status' %></th>
                <% if (locals.user && user.role === 'admin') { %><th></th><% } %>
              </tr>
            </thead>
            <tbody>
              <% tenantHistory.forEach(h => { %>
              <tr>
                <td class="fw-600"><%= h.full_name %></td>
                <td><%= h.lease_start %></td>
                <td><%= h.lease_end || '—' %></td>
                <td><span class="badge <%= h.is_current ? 'badge-active' : 'badge-past' %>"><%= h.is_current ? (isAr ? 'حالي' : 'Current') : (isAr ? 'سابق' : 'Past') %></span></td>
                <% if (locals.user && user.role === 'admin') { %>
                <td class="text-end">
                  <a href="/units/<%= unit.id %>/assignments/<%= h.lease_id %>/edit" class="btn btn-outline-secondary btn-sm"><i class="bi bi-pencil"></i></a>
                </td>
                <% } %>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
      <% } %>

      <!-- Recent Payments -->
      <div class="card">
        <div class="card-header">
          <%= isAr ? 'المدفوعات الأخيرة' : 'Recent Payments' %>
          <% if (currentTenant && locals.user && (user.role === 'admin' || user.role === 'cashier')) { %>
          <a href="/payments/new?unit_id=<%= unit.id %>" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg"></i> <%= isAr ? 'تسجيل دفعة' : 'Record Payment' %>
          </a>
          <% } %>
        </div>
        <% if (payments.length === 0) { %>
        <div class="empty-state"><div class="empty-icon">💳</div><h6><%= isAr ? 'لا توجد مدفوعات' : 'No Payments' %></h6><p><%= isAr ? 'لا توجد سجلات مدفوعات لهذه الوحدة بعد.' : 'No payment records for this unit yet.' %></p></div>
        <% } else { %>
        <div class="table-responsive">
          <table class="table mb-0">
            <thead>
              <tr>
                <th><%= isAr ? 'التاريخ' : 'Date' %></th>
                <th><%= isAr ? 'رقم الإيصال' : 'Receipt #' %></th>
                <th><%= isAr ? 'المستأجر' : 'Tenant' %></th>
                <th><%= isAr ? 'المبلغ' : 'Amount' %></th>
                <th><%= isAr ? 'الطريقة' : 'Method' %></th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% payments.forEach(p => { %>
              <tr>
                <td><%= p.payment_date %></td>
                <td class="fw-600">#<%= p.receipt_number %></td>
                <td><%= p.tenant_name %></td>
                <td class="fw-600 text-success"><%= currencyLabel %> <%= p.total_amount.toFixed(3) %></td>
                <td><span class="badge badge-<%= p.payment_method %>"><%= p.payment_method %></span></td>
                <td class="text-end">
                  <a href="/payments/<%= p.id %>" class="btn btn-outline-secondary btn-sm"><%= isAr ? 'عرض' : 'View' %></a>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<% if (groupInfo && locals.user && user.role === 'admin' && !currentTenant) { %>
<!-- Dissolve Group Modal -->
<div class="modal fade" id="dissolveModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-x-circle me-2"></i><%= isAr ? 'حل مجموعة الدمج' : 'Dissolve Merge Group' %></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" style="font-size:13.5px;">
        <p><%= isAr ? 'سيؤدي هذا إلى حل مجموعة' : 'This will dissolve the group' %> <strong><%= unit.name %></strong> <%= isAr ? 'وإعادة الوحدات التالية إلى حالة مستقلة (شاغرة):' : 'and restore the following units to independent (vacant) status:' %></p>
        <ul class="mb-0">
          <% groupMembers.forEach(m => { %>
          <li><%= m.unit_number || m.name %></li>
          <% }) %>
        </ul>
        <div class="alert alert-warning mt-3 mb-0" style="font-size:12.5px;">
          <i class="bi bi-exclamation-triangle me-1"></i>
          <%= isAr ? 'متاح فقط عند غياب مدفوعات ومستأجر نشط على وحدة المجموعة.' : 'Only possible when the group unit has no payments and no active tenant.' %>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal"><%= isAr ? 'إلغاء' : 'Cancel' %></button>
        <form action="/units/groups/<%= groupInfo.id %>/dissolve" method="POST">
          <button type="submit" class="btn btn-danger btn-sm"><i class="bi bi-x-circle"></i> <%= isAr ? 'حل المجموعة' : 'Dissolve' %></button>
        </form>
      </div>
    </div>
  </div>
</div>
<% } %>

<% if (locals.user && user.role === 'admin') { %>
<!-- Assign Tenant Modal -->
<div class="modal fade" id="assignModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-person-plus me-2"></i><%= isAr ? 'تعيين مستأجر' : 'Assign Tenant' %></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form id="assignForm" action="/units/<%= unit.id %>/assign" method="POST">
        <div class="modal-body">
          <div id="existingTenantSelect" class="mb-3">
            <label class="form-label"><%= isAr ? 'المستأجر' : 'Tenant' %> <span class="text-danger">*</span></label>
            <select name="tenant_id" class="form-select" required>
              <option value=""><%= isAr ? 'اختر مستأجراً…' : 'Select tenant…' %></option>
              <% availableTenants.forEach(t => { %>
              <option value="<%= t.id %>"><%= t.full_name %><%= t.tel ? ' — ' + t.tel : '' %></option>
              <% }) %>
            </select>
          </div>
          <div class="text-end mb-2" style="font-size:12.5px;">
            <a href="#" id="toggleCreateTenant" onclick="toggleNewTenant(event)">
              <i class="bi bi-plus-circle me-1"></i><%= isAr ? 'إنشاء مستأجر جديد' : '+ Create New Tenant' %>
            </a>
          </div>
          <div id="newTenantFields" style="display:none;">
            <hr style="margin:0.5rem 0;">
            <div class="mb-2">
              <label class="form-label"><%= isAr ? 'الاسم الكامل' : 'Full Name' %> <span class="text-danger">*</span></label>
              <input type="text" name="full_name" class="form-control" placeholder="...">
            </div>
            <div class="mb-3">
              <label class="form-label"><%= isAr ? 'رقم الهاتف' : 'Phone' %></label>
              <input type="text" name="tel" class="form-control" placeholder="...">
            </div>
          </div>
          <div class="row g-3">
            <div class="col-6">
              <label class="form-label"><%= isAr ? 'بداية العقد' : 'Lease Start' %> <span class="text-danger">*</span></label>
              <input type="date" name="lease_start" class="form-control" required value="<%= new Date().toISOString().slice(0,10) %>">
            </div>
            <div class="col-6">
              <label class="form-label"><%= isAr ? 'نهاية العقد' : 'Lease End' %></label>
              <input type="date" name="lease_end" class="form-control">
              <div class="form-text"><%= isAr ? 'اتركه فارغاً للعقد المفتوح' : 'Leave blank for open-ended' %></div>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal"><%= isAr ? 'إلغاء' : 'Cancel' %></button>
          <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-check-lg"></i> <%= isAr ? 'تعيين' : 'Assign' %></button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Vacate Modal -->
<div class="modal fade" id="vacateModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-person-dash me-2"></i><%= isAr ? 'وضع علامة شاغرة' : 'Mark as Vacant' %></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/units/<%= unit.id %>/vacate" method="POST">
        <div class="modal-body" style="font-size:13.5px;">
          <p><%= isAr ? 'إنهاء العقد الحالي وتحديد الوحدة شاغرة.' : 'End the current lease and mark this unit as vacant.' %></p>
          <div class="mb-3">
            <label class="form-label"><%= isAr ? 'تاريخ انتهاء العقد' : 'Lease End Date' %></label>
            <input type="date" name="lease_end" class="form-control" value="<%= new Date().toISOString().slice(0,10) %>">
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal"><%= isAr ? 'إلغاء' : 'Cancel' %></button>
          <button type="submit" class="btn btn-warning btn-sm"><i class="bi bi-check-lg"></i> <%= isAr ? 'وضع شاغرة' : 'Mark Vacant' %></button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Archive Modal -->
<div class="modal fade" id="archiveModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-archive me-2"></i><%= isAr ? 'أرشفة الوحدة' : 'Archive Unit' %></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" style="font-size:13.5px;">
        <%= isAr ? 'أرشفة الوحدة' : 'Archive unit' %> <strong><%= unit.name %></strong>? <%= isAr ? 'لن تظهر في القوائم النشطة.' : 'It will no longer appear in active listings.' %>
      </div>
      <div class="modal-footer">
        <button class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal"><%= isAr ? 'إلغاء' : 'Cancel' %></button>
        <form action="/units/<%= unit.id %>/archive" method="POST">
          <button type="submit" class="btn btn-danger btn-sm"><i class="bi bi-archive"></i> <%= isAr ? 'أرشفة' : 'Archive' %></button>
        </form>
      </div>
    </div>
  </div>
</div>
<% } %>

<%- include('../partials/scripts') %>
<script>
function toggleNewTenant(e) {
  e.preventDefault();
  const showing = document.getElementById('newTenantFields').style.display !== 'none';
  document.getElementById('newTenantFields').style.display = showing ? 'none' : '';
  document.getElementById('existingTenantSelect').style.display = showing ? '' : 'none';
  const form = document.getElementById('assignForm');
  form.action = showing
    ? '/units/<%= unit.id %>/assign'
    : '/units/<%= unit.id %>/assign-new-tenant';
  document.querySelector('select[name="tenant_id"]').required = showing;
  document.querySelector('input[name="full_name"]').required = !showing;
  document.getElementById('toggleCreateTenant').innerHTML = showing
    ? '<i class="bi bi-plus-circle me-1"></i><%= isAr ? "إنشاء مستأجر جديد" : "+ Create New Tenant" %>'
    : '<i class="bi bi-arrow-left me-1"></i><%= isAr ? "اختر مستأجراً موجوداً" : "← Select existing tenant" %>';
}
</script>
