<%- include('../partials/head') %>
<% const isAr = (locals.lang || 'en') === 'ar'; %>
<div class="app-wrapper">
  <%- include('../partials/sidebar') %>

  <div class="main-content">
    <div class="topbar">
      <span class="topbar-title"><i class="bi bi-headset me-2"></i><%= isAr ? 'الدعم الفني' : 'Support' %></span>
      <div class="topbar-actions">
        <a href="/support/new" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg"></i> <%= isAr ? 'تذكرة جديدة' : 'New Ticket' %></a>
      </div>
    </div>

    <div class="page-body">
      <% if (flash) { %>
      <div class="alert alert-<%= flash.type %> mb-3" data-autohide><%= flash.msg %></div>
      <% } %>

      <% if (tickets.length === 0) { %>
      <div class="card">
        <div class="card-body text-center py-5">
          <i class="bi bi-ticket-perforated" style="font-size:2.5rem;opacity:0.3;"></i>
          <p class="mt-3 text-muted"><%= isAr ? 'لا توجد تذاكر دعم بعد.' : 'No support tickets yet.' %></p>
          <a href="/support/new" class="btn btn-primary btn-sm mt-1"><%= isAr ? 'افتح تذكرة' : 'Open a Ticket' %></a>
        </div>
      </div>
      <% } else { %>
      <div class="card">
        <div class="card-body p-0">
          <table class="table table-hover mb-0">
            <thead>
              <tr>
                <th>#</th>
                <th><%= isAr ? 'الموضوع' : 'Subject' %></th>
                <th><%= isAr ? 'الأولوية' : 'Priority' %></th>
                <th><%= isAr ? 'الحالة' : 'Status' %></th>
                <th><%= isAr ? 'آخر تحديث' : 'Last Updated' %></th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% tickets.forEach(ticket => { %>
              <%
                const statusMap = { open: 'warning', in_progress: 'info', resolved: 'success', closed: 'secondary' };
                const priorityMap = { low: 'secondary', normal: 'primary', high: 'warning', urgent: 'danger' };
                const statusBadge = statusMap[ticket.status] || 'secondary';
                const priorityBadge = priorityMap[ticket.priority] || 'secondary';
              %>
              <tr>
                <td class="text-muted" style="font-size:0.8rem;">#<%= ticket.id %></td>
                <td><%= ticket.subject %></td>
                <td><span class="badge bg-<%= priorityBadge %>-subtle text-<%= priorityBadge %>-emphasis border border-<%= priorityBadge %>-subtle"><%= ticket.priority %></span></td>
                <td><span class="badge bg-<%= statusBadge %>-subtle text-<%= statusBadge %>-emphasis border border-<%= statusBadge %>-subtle"><%= ticket.status.replace('_',' ') %></span></td>
                <td style="font-size:0.8rem;" class="text-muted"><%= new Date(ticket.updated_at).toLocaleDateString() %></td>
                <td><a href="/support/<%= ticket.id %>" class="btn btn-outline-secondary btn-sm"><%= isAr ? 'عرض' : 'View' %></a></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</div>
<%- include('../partials/scripts') %>
